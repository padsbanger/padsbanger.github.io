---
import Layout from '../layouts/Layout.astro';

import '../styles/home.css';

const featuredProjects = [
	{
		code: 'N-24',
		title: 'Nordea',
		type: 'Senior Frontend Engineer / May 2024 - Present',
		description:
			'Developing internal platforms for API onboarding, enterprise services, secure AI access management, and Redis tooling across engineering teams.',
		stats: ['Enterprise platform', 'API integrations', 'AI tooling', 'Security'],
		link: 'https://www.nordea.com/en/our-services/technology/',
	},
	{
		code: 'M-20',
		title: 'MasterBorn',
		type: 'Frontend / Lead Frontend Engineer / Aug 2020 - Apr 2024',
		description:
			'Led React and TypeScript frontend work for payment processing at Payments.ai and  sports video streaming at watch.outsideonline.com, cycling analytics, and medical device inspection workflows.',
		stats: ['Redux', 'Next.js', 'TypeScript', 'Payments processing', "Video streaming",],
		link: 'https://www.masterborn.com/',
	},
	{
		code: 'J-19',
		title: 'JIT Team',
		type: 'Frontend Engineer / Feb 2019 - Jul 2020',
		description:
			'Built hybrid PWA applications for ship inspection processes and frontend systems for smart city and IoT management platforms.',
		stats: ['React', 'Material UI', 'PWA', 'IoT', 'Inspection tools'],
		link: 'https://www.jit.team/',
	},
	{
		code: 'S-16',
		title: 'Schibsted Tech Polska',
		type: 'UI Developer / Lead Frontend Developer / Jul 2016 - Jan 2019',
		description:
			'Led frontend development for booking and marketplace platform Styletime.no, recommendation features, and reusable component architecture.',
		stats: ['SRR', 'Tailwind CSS', 'Tanstack Query', 'Marketplaces',],
		link: 'https://www.schibsted.pl/technology/',
	},
	{
		code: 'E-15',
		title: 'EPAM Systems',
		type: 'UI Software Developer / May 2015 - Jun 2016',
		description:
			'Worked on internal enterprise frontend projects, performed code reviews, and contributed to shared development standards.',
		stats: ['Enterprise UI', 'Reviews', 'Standards'],
		link: 'https://www.epam.com/',
	},
	{
		code: 'M-13',
		title: 'Misys',
		type: 'Software Developer / Aug 2013 - Apr 2015',
		description:
			'Developed frontend features for financial risk analysis software, maintained cross-browser compatibility, and introduced end-to-end testing practices.',
		stats: ['Fintech', 'E2E testing', 'Compatibility'],
		link: 'https://www.finastra.com/',
	},
];

const sideProjects = [
	{
		code: 'GH-01',
		title: 'Omnia',
		status: 'TypeScript',
		description:
			'Desktop workspace organizer that unifies web-based apps like messaging, email, and productivity tools into one focused multitasking environment.',
		tags: ['Electron', 'Desktop app', 'Productivity'],
		link: 'https://github.com/padsbanger/omnia',
	},
	{
		code: 'GH-02',
		title: 'Bandcamp Archiver',
		status: 'Rust',
		description:
			'CLI tool for archiving Bandcamp albums, built as a focused utility around collection preservation and local music workflows.',
		tags: ['Rust', 'CLI', 'Music archive'],
		link: 'https://github.com/padsbanger/bandcamp-archiver',
	},
	{
		code: 'GH-03',
		title: 'Spotify TUI',
		status: 'TypeScript',
		description:
			'Simple terminal client for Spotify, exploring command-line music control through a lightweight text interface.',
		tags: ['TypeScript', 'Terminal UI', 'Spotify'],
		link: 'https://github.com/padsbanger/spotify-tui',
	},
];

const systems = [
	{ label: 'Frontend', value: 'React, Next.js, TypeScript, JavaScript, HTML5, CSS3' },
	{ label: 'State', value: 'Redux Toolkit, Zustand, MobX, Context API, RTK Query' },
	{ label: 'APIs', value: 'REST, GraphQL, Apollo Client, Axios, Fetch' },
	{ label: 'Styling', value: 'Tailwind CSS, Styled Components, Emotion, CSS Modules, Sass' },
	{ label: 'Testing', value: 'Jest, React Testing Library, Vitest, Protractor' },
	{ label: 'Tooling', value: 'Vite, Webpack, Docker, Git, GitHub, Jenkins, TeamCity' },
	{ label: 'AI', value: 'Ollama, Copilot, vLLM, ollama.cpp' },
	
];

const seoKeywords = [
	'Michal Lach',
	'Senior Frontend Engineer',
	'Frontend Engineer Poland',
	'React developer',
	'TypeScript developer',
	'Next.js developer',
	'frontend architecture',
	'design systems',
	'web performance',
	'Gdansk frontend engineer',
];

const structuredData = [
	{
		'@context': 'https://schema.org',
		'@type': 'Person',
		name: 'Michal Lach',
		url: 'https://michal-lach.pl',
		jobTitle: 'Senior Frontend Engineer',
		address: {
			'@type': 'PostalAddress',
			addressLocality: 'Gdynia',
			addressCountry: 'PL',
		},
		email: 'mailto:kontakt@michal-lach.pl',
		sameAs: [
			'https://github.com/padsbanger',
			'https://www.linkedin.com/in/micha%C5%82-lach-98854a6b/',
		],
		alumniOf: {
			'@type': 'CollegeOrUniversity',
			name: 'Polish-Japanese Academy of Information Technology',
		},
		knowsAbout: [
			'React',
			'Next.js',
			'TypeScript',
			'Frontend architecture',
			'Design systems',
			'Web performance',
			'Developer experience',
		],
	},
	{
		'@context': 'https://schema.org',
		'@type': 'WebSite',
		name: 'Michal Lach',
		url: 'https://michal-lach.pl',
		description:
			'Portfolio website of Michal Lach, Senior Frontend Engineer specializing in React, TypeScript, frontend architecture, and scalable web applications.',
	},
];
---

<Layout
	title="Michal Lach | Senior Frontend Engineer"
	description="Senior Frontend Engineer based in Gdansk, Poland, specializing in React, TypeScript, frontend architecture, design systems, and scalable web applications."
	keywords={seoKeywords}
	structuredData={structuredData}
>
	<div class="three-backdrop" id="three-backdrop" aria-hidden="true"></div>
	<main class="shell">
		<header class="topbar intro-reveal">
			<div class="brand">
				<div class="brand-emblem">
					<span></span>
				</div>
				<div>
					<p class="label">Michal Lach</p>
					<p class="subtle">Frontend Engineer / React / TypeScript / architecture</p>
				</div>
			</div>

			<nav class="nav-tabs" aria-label="Primary">
				<a class="is-active" href="#overview">Overview</a>
				<a href="#missions">Experience</a>
				<a href="#side-projects">Side Projects</a>
				<a href="#systems">Systems</a>
				<a href="#contact">Contact</a>
			</nav>
		</header>

		<section class="command-frame panel" id="overview">
			<div class="frame-header intro-reveal">
				<div class="header-block">
					<p class="label">Operator</p>
					<strong>Michal Lach</strong>
				</div>
				<div class="header-block">
					<p class="label">Status</p>
					<strong>Frontend Engineer available for forward deployment</strong>
				</div>
				<div class="header-block">
					<p class="label">Region</p>
					<strong>Gdynia, Poland / Earth / Sol System</strong>
				</div>
			</div>

			<div class="frame-body">
				<div class="hero-copy intro-reveal">
					<p class="eyebrow">Navigation Summary</p>
					<h1>Building scalable frontend systems for complex products.</h1>
					<p class="lede">
						I am a Frontend Engineer focused on React, TypeScript, performance optimization,
						component design systems, state management, and developer experience across fintech,
						AI, enterprise, healthcare, and media products.
					</p>
					<div class="action-row">
						<a class="button-primary" href="#missions">Open Experience Log</a>
						<a class="button-secondary" href="#contact">Contact</a>
						<a class="button-secondary" href="/cv.pdf" target="_blank" rel="noreferrer">View CV</a>
					</div>
				</div>

				<div class="scanner-panel">
					<div class="scanner-graphic scanner-boot" id="scanner-graphic">
						<div class="scanner-three" id="scanner-three" aria-hidden="true"></div>
						<div class="ring ring-1"></div>
						<div class="ring ring-2"></div>
						<div class="ring ring-3"></div>
						<div class="axis axis-h"></div>
						<div class="axis axis-v"></div>
						<div class="scanner-boot-overlay" id="scanner-boot-overlay" aria-live="polite">
							<p class="scanner-boot-label">Navigation Boot</p>
							<p class="scanner-boot-status" id="scanner-boot-status">Initializing stellar map</p>
							<div class="scanner-boot-bar">
								<span class="scanner-boot-fill"></span>
							</div>
						</div>
						<div class="scanner-event-layer" aria-hidden="true">
							<div class="signal-line" id="signal-line"></div>
							<div class="scanner-comet" id="scanner-comet">
								<span class="scanner-comet-tail"></span>
								<span class="scanner-comet-core"></span>
							</div>
							<div class="scanner-disturbance" id="scanner-disturbance"></div>
						</div>
						<button class="sun-core scanner-target" type="button" data-target="sun" data-section="overview" aria-label="Open overview section"></button>
						<button class="node node-1 scanner-target" type="button" data-target="aurelia" data-section="missions" aria-label="Open experience section"></button>
						<button class="node node-2 scanner-target" type="button" data-target="vesper" data-section="side-projects" aria-label="Open side projects section"></button>
						<button class="node node-3 scanner-target" type="button" data-target="khepri" data-section="systems" aria-label="Open systems section"></button>
						<div class="scan-line"></div>
					</div>
					<div class="scanner-readout intro-reveal">
						<div>
							<p class="label">Discipline</p>
							<strong>Frontend architecture and product engineering</strong>
						</div>
						<div>
							<p class="label">Stack</p>
							<strong>React / Next.js / TypeScript / LLM</strong>
						</div>
						<div>
							<p class="label">Priority</p>
							<strong>Maintainable, scalable, production-grade web applications</strong>
						</div>
					</div>
				</div>
			</div>
		</section>

		<section class="overview-grid intro-reveal">
			<article class="panel info-panel">
				<p class="label">Profile</p>
				<p>10+ years delivering production frontend systems with product, backend, and design teams in agile environments.</p>
			</article>
			<article class="panel info-panel">
				<p class="label">Industries</p>
				<p>Fintech, AI platforms, enterprise tooling, healthcare workflows, media products, IoT, and smart city systems.</p>
			</article>
			<article class="panel info-panel">
				<p class="label">Education</p>
				<p>Bachelor's Degree in Information Technology, plus Cambridge First Certificate in English at B2 level.</p>
			</article>
		</section>

		<section class="section-head intro-reveal" id="missions">
			<p class="eyebrow">Experience Log</p>
			<h2>Professional roles mapped as active records in a navigation console.</h2>
		</section>

		<section class="mission-grid intro-reveal">
			{featuredProjects.map((project) => (
				<article class="panel mission-card">
					<div class="mission-top">
						<span class="mission-code">{project.code}</span>
						<span class="mission-type">{project.type}</span>
					</div>
					<h3>{project.title}</h3>
					<p>{project.description}</p>
					<div class="stat-row">
						{project.stats.map((stat) => (
							<span>{stat}</span>
						))}
					</div>
					<a class="text-link" href={project.link} target="_blank" rel="noreferrer">Open company</a>
				</article>
			))}
		</section>

		<section class="section-head intro-reveal" id="side-projects">
			<p class="eyebrow">GitHub Signals</p>
			<h2>Side projects staged for success.</h2>
		</section>

		<section class="side-project-grid intro-reveal">
			{sideProjects.map((project) => (
				<article class="panel side-project-card">
					<div class="side-project-top">
						<span class="mission-code">{project.code}</span>
						<span class="mission-type">{project.status}</span>
					</div>
					<h3>{project.title}</h3>
					<p>{project.description}</p>
					<div class="stat-row">
						{project.tags.map((tag) => (
							<span>{tag}</span>
						))}
					</div>
					<a class="text-link" href={project.link} target="_blank" rel="noreferrer">Open GitHub</a>
				</article>
			))}
		</section>

		<section class="systems-layout intro-reveal" id="systems">
			<div class="section-head compact">
				<p class="eyebrow">Systems</p>
				<h2>Technical toolkit for scalable frontend delivery.</h2>
				<p class="lede compact-text">
					Strong focus on component architecture, state management, performance, testing,
					developer experience, and collaboration across design and engineering workflows.
				</p>
			</div>

			<div class="panel systems-panel">
				{systems.map((item) => (
					<div class="system-row">
						<p class="label">{item.label}</p>
						<strong>{item.value}</strong>
					</div>
				))}
			</div>
		</section>

		<section class="panel contact-panel intro-reveal" id="contact">
			<div class="contact-copy">
				<p class="eyebrow">Contact Uplink</p>
				<h2>Available for frontend engineering conversations.</h2>
				<p>
					Open to frontend roles, architecture-heavy product work, and teams that care
					about building maintainable and usable systems.
				</p>
			</div>
			<div class="contact-meta">
				<div class="contact-status">
					<span></span>
					<p>Channel status: receiving</p>
				</div>
				<div class="contact-channel-list">
					<a class="contact-channel" href="mailto:kontakt@michal-lach.pl">
						<span class="contact-icon" aria-hidden="true">
							<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round">
								<path d="M4 6.5h16a1.5 1.5 0 0 1 1.5 1.5v8a1.5 1.5 0 0 1-1.5 1.5H4A1.5 1.5 0 0 1 2.5 16V8A1.5 1.5 0 0 1 4 6.5Z"></path>
								<path d="m3.5 8 8.5 6 8.5-6"></path>
							</svg>
						</span>
						<span>Email</span>
						<strong>kontakt@michal-lach.pl</strong>
					</a>
					<a class="contact-channel" href="https://github.com/padsbanger" target="_blank" rel="noreferrer">
						<span class="contact-icon" aria-hidden="true">
							<svg viewBox="0 0 24 24" fill="currentColor">
								<path d="M12 .8a12 12 0 0 0-3.8 23.4c.6.1.8-.3.8-.6v-2.2c-3.3.7-4-1.4-4-1.4-.5-1.3-1.2-1.7-1.2-1.7-1-.7.1-.7.1-.7 1.1.1 1.7 1.1 1.7 1.1 1 .1 1.9-.8 2.3-1.2.1-.7.4-1.2.7-1.5-2.7-.3-5.6-1.3-5.6-6A4.7 4.7 0 0 1 5 6.8c-.1-.3-.5-1.5.1-3 0 0 1-.3 3.2 1.2a11 11 0 0 1 5.8 0c2.2-1.5 3.2-1.2 3.2-1.2.6 1.5.2 2.7.1 3a4.7 4.7 0 0 1 1.3 3.3c0 4.7-2.9 5.7-5.6 6 .4.3.8 1 .8 2v3c0 .3.2.7.8.6A12 12 0 0 0 12 .8Z"></path>
							</svg>
						</span>
						<span>GitHub</span>
						<strong>github.com/padsbanger</strong>
					</a>
					<a class="contact-channel" href="https://www.linkedin.com/in/micha%C5%82-lach-98854a6b/" target="_blank" rel="noreferrer">
						<span class="contact-icon" aria-hidden="true">
							<svg viewBox="0 0 24 24" fill="currentColor">
								<path d="M5.4 8.6A1.8 1.8 0 1 1 5.4 5a1.8 1.8 0 0 1 0 3.6ZM3.8 9.9h3.1v10.3H3.8V9.9Zm5 0h3v1.4h.1c.4-.8 1.5-1.7 3.1-1.7 3.4 0 4 2.1 4 4.9v5.7h-3.1v-5c0-1.2 0-2.8-1.8-2.8s-2 1.3-2 2.7v5.1H8.8V9.9Z"></path>
							</svg>
						</span>
						<span>LinkedIn</span>
						<strong>linkedin.com/in/michal-lach</strong>
					</a>
				</div>
				<div class="contact-links">
					<a class="button-primary" href="mailto:kontakt@michal-lach.pl">Transmit Email</a>
					<a class="button-secondary" href="https://www.linkedin.com/in/michal-lach/" target="_blank" rel="noreferrer">Open LinkedIn</a>
					<a class="button-secondary" href="/cv.pdf" target="_blank" rel="noreferrer">View CV</a>
				</div>
			</div>
		</section>
	</main>
</Layout>

<script src="../scripts/home.js"></script>
