---
import Layout from '../layouts/Layout.astro';

import '../styles/home.css';

const experience = [
	{
		tag: 'N-24 · Enterprise / AI',
		year: 'May 2024 — Present',
		title: 'Nordea',
		role: 'Senior Frontend Engineer',
		text: 'Developing internal platforms for API onboarding, enterprise services, secure AI access management, and Redis tooling across engineering teams.',
		stack: ['Enterprise platform', 'API integrations', 'AI tooling', 'Security'],
	},
	{
		tag: 'M-20 · Payments / Media',
		year: 'Aug 2020 — Apr 2024',
		title: 'MasterBorn',
		role: 'Frontend / Lead Frontend Engineer',
		text: 'Led React and TypeScript frontend work for payment processing at Payments.ai and sports video streaming at watch.outsideonline.com, cycling analytics, and medical device inspection workflows.',
		stack: ['Redux', 'Next.js', 'TypeScript', 'Payments', 'Video streaming'],
	},
	{
		tag: 'J-19 · IoT / Smart city',
		year: 'Feb 2019 — Jul 2020',
		title: 'JIT Team',
		role: 'Frontend Engineer',
		text: 'Built hybrid PWA applications for ship inspection processes and frontend systems for smart city and IoT management platforms.',
		stack: ['React', 'Material UI', 'PWA', 'IoT', 'Inspection tools'],
	},
	{
		tag: 'S-16 · Marketplaces',
		year: 'Jul 2016 — Jan 2019',
		title: 'Schibsted Tech Polska',
		role: 'UI Developer / Lead Frontend Developer',
		text: 'Led frontend development for booking and marketplace platform Styletime.no, recommendation features, and reusable component architecture.',
		stack: ['SSR', 'Tailwind CSS', 'TanStack Query', 'Marketplaces'],
	},
	{
		tag: 'E-15 · Enterprise',
		year: 'May 2015 — Jun 2016',
		title: 'EPAM Systems',
		role: 'UI Software Developer',
		text: 'Worked on internal enterprise frontend projects, performed code reviews, and contributed to shared development standards.',
		stack: ['Enterprise UI', 'Reviews', 'Standards'],
	},
	{
		tag: 'M-13 · Fintech',
		year: 'Aug 2013 — Apr 2015',
		title: 'Misys',
		role: 'Software Developer',
		text: 'Developed frontend features for financial risk analysis software, maintained cross-browser compatibility, and introduced end-to-end testing practices.',
		stack: ['Fintech', 'E2E testing', 'Compatibility'],
	},
];

const sideProjects = [
	{
		tag: 'GH-01 · TypeScript',
		title: 'Omnia',
		text: 'Desktop workspace organizer that unifies web-based apps like messaging, email, and productivity tools into one focused multitasking environment.',
		stack: ['Electron', 'Desktop app', 'Productivity'],
		link: 'https://github.com/padsbanger/omnia',
	},
	{
		tag: 'GH-02 · Rust',
		title: 'Bandcamp Archiver',
		text: 'CLI tool for archiving Bandcamp albums, built as a focused utility around collection preservation and local music workflows.',
		stack: ['Rust', 'CLI', 'Music archive'],
		link: 'https://github.com/padsbanger/bandcamp-archiver',
	},
	{
		tag: 'GH-03 · TypeScript',
		title: 'Spotify TUI',
		text: 'Simple terminal client for Spotify, exploring command-line music control through a lightweight text interface.',
		stack: ['TypeScript', 'Terminal UI', 'Spotify'],
		link: 'https://github.com/padsbanger/spotify-tui',
	},
		{
		tag: 'GH-04 · Webkit Extension',
		title: 'YouTube Subscriptions Fixer',
		text: 'Extension for Webkit based browsers (Chrome & Brave) to bring back old subscriptions view.',
		stack: ['TypeScript', 'Chrome/Webkit', 'Youtube'],
		link: 'https://github.com/padsbanger/chrome-youtube-subscriptions',
	},
];

const systems = [
	{ label: 'Frontend', value: 'React, Next.js, TypeScript, JavaScript, HTML5, CSS3' },
	{ label: 'State', value: 'Redux Toolkit, Zustand, MobX, Context API, RTK Query' },
	{ label: 'APIs', value: 'REST, GraphQL, Apollo Client, Axios, Fetch' },
	{ label: 'Styling', value: 'Tailwind CSS, Styled Components, Emotion, CSS Modules, Sass' },
	{ label: 'Testing', value: 'Jest, React Testing Library, Vitest, Protractor' },
	{ label: 'Tooling', value: 'Vite, Webpack, Docker, Git, GitHub, Jenkins, TeamCity' },
	{ label: 'AI', value: 'Ollama, Copilot, vLLM, ollama.cpp' },
];

const aboutItems = [
	{
		label: 'Profile',
		text: '10+ years delivering production frontend systems with product, backend, and design teams in agile environments.',
	},
	{
		label: 'Industries',
		text: 'Fintech, AI platforms, enterprise tooling, healthcare workflows, media products, IoT, and smart city systems.',
	},
	{
		label: 'Education',
		text: "Bachelor's Degree in Information Technology, plus Cambridge First Certificate in English at B2 level.",
	},
];

const marqueeItems = ['React', '·', 'TypeScript', '·', 'Next.js', '·', 'Redux Toolkit', '·', 'GraphQL', '·', 'Tailwind CSS', '·', 'Styled Components', '.', 'Vite', '·', 'Testing', '·'];

const seoKeywords = [
	'Michał Lach',
	'Senior Frontend Engineer',
	'Frontend Engineer Poland',
	'React developer',
	'TypeScript developer',
	'Next.js developer',
	'frontend architecture',
	'design systems',
	'web performance',
	'Gdynia frontend engineer',
];

const structuredData = [
	{
		'@context': 'https://schema.org',
		'@type': 'Person',
		name: 'Michał Lach',
		url: 'https://michal-lach.pl',
		jobTitle: 'Senior Frontend Engineer',
		image: 'https://michal-lach.pl/og-image.png',
		address: {
			'@type': 'PostalAddress',
			addressLocality: 'Gdynia',
			addressCountry: 'PL',
		},
		worksFor: {
			'@type': 'Organization',
			name: 'Nordea',
		},
		email: 'mailto:kontakt@michal-lach.pl',
		sameAs: [
			'https://github.com/padsbanger',
			'https://www.linkedin.com/in/micha%C5%82-lach-98854a6b/',
		],
		alumniOf: {
			'@type': 'CollegeOrUniversity',
			name: 'Polish-Japanese Academy of Information Technology',
		},
		knowsAbout: [
			'React',
			'Next.js',
			'TypeScript',
			'Frontend architecture',
			'Design systems',
			'Web performance',
			'Developer experience',
		],
	},
	{
		'@context': 'https://schema.org',
		'@type': 'WebSite',
		name: 'Michał Lach',
		url: 'https://michal-lach.pl',
		description:
			'Portfolio website of Michał Lach, Senior Frontend Engineer specializing in React, TypeScript, frontend architecture, and scalable web applications.',
	},
];
---

<Layout
	title="Michał Lach — Senior Frontend Engineer"
	description="Michał Lach is a Senior Frontend Engineer building scalable frontend systems for complex products — React, TypeScript, Next.js, architecture."
	keywords={seoKeywords}
	structuredData={structuredData}
>
	<div class="top-anchor" id="top" aria-hidden="true"></div>

	<div class="boot" id="boot" aria-hidden="true">
		<div class="boot-shell">
			<div class="boot-head">
				<span>Bootloader sequence</span>
				<strong>ML://portfolio</strong>
			</div>
			<pre class="boot-log" id="boot-log"></pre>
			<div class="boot-progress" aria-hidden="true">
				<span></span>
			</div>
			<span class="boot-skip">[ press any key to skip ]</span>
		</div>
	</div>

	<div class="spotlight" id="spotlight" aria-hidden="true"></div>
	<div class="scroll-progress" aria-hidden="true">
		<span id="scroll-progress-bar"></span>
	</div>

	<header class="site-header">
		<a href="#top" class="brand">
			<span class="brand-mark">ML</span>
			<span class="brand-name">Michał&nbsp;Lach</span>
		</a>
		<nav class="nav" aria-label="Primary">
			<a href="#experience"><span class="num">01</span> Experience</a>
			<a href="#projects"><span class="num">02</span> Projects</a>
			<a href="#systems"><span class="num">03</span> Systems</a>
			<a href="#about"><span class="num">04</span> About</a>
			<a href="#contact"><span class="num">05</span> Contact</a>
		</nav>
		<div class="header-actions">
			<button type="button" class="theme-toggle" id="theme-toggle" aria-label="Toggle dark mode" title="Toggle theme">
				<svg class="icon-moon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
					<path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8z" />
				</svg>
				<svg class="icon-sun" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
					<circle cx="12" cy="12" r="4" />
					<path d="M12 2v2M12 20v2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M2 12h2M20 12h2M4.9 19.1l1.4-1.4M17.7 6.3l1.4-1.4" />
				</svg>
			</button>
			<a href="#contact" class="btn btn--solid">Let's talk</a>
		</div>
	</header>

	<main>
		<section class="hero">
			<div class="hero-frame">
				<span class="tick tick--tl" aria-hidden="true"></span>
				<span class="tick tick--tr" aria-hidden="true"></span>
				<span class="tick tick--bl" aria-hidden="true"></span>
				<span class="tick tick--br" aria-hidden="true"></span>

				<div class="hero-meta" aria-hidden="true">
					<span class="hero-meta-item">The desk of Michał Lach</span>
					<span class="hero-meta-item">Frontend · Systems · Delivery</span>
					<span class="hero-meta-item hero-meta-item--clock">
						<span id="hud-date">···, ··· ·· ····</span> · <span id="hud-clock">··:··:··</span> UTC
					</span>
				</div>

				<p class="eyebrow reveal">Senior Frontend Engineer — Gdynia, PL / Remote</p>
				<h1 class="hero-title">
					<span class="sr-only">Michał Lach — Senior Frontend Engineer.</span>
					<span class="reveal" style="--d:0">Building <br />scalable <br/> frontend</span>
					<span class="reveal accent" style="--d:0">systems</span>
					<span class="reveal" style="--d:0"> for complex </span>
					<span class="reveal accent" style="--d:1">products.</span>
				</h1>
				<p class="hero-sub reveal" style="--d:2">
					Frontend Engineer focused on performance, component design systems,
					state management, and developer experience across fintech, AI,
					enterprise, healthcare, and media products.
				</p>

				<dl class="readouts reveal" style="--d:3">
					<div class="readout">
						<dt>Status</dt>
						<dd>Deployed in production <span class="dot dot--live" aria-hidden="true"></span></dd>
					</div>
					<div class="readout">
						<dt>Sector</dt>
						<dd>AI / Enterprise / Fintech</dd>
					</div>
					<div class="readout">
						<dt>Location</dt>
						<dd>Gdynia, PL · Remote</dd>
					</div>
					<div class="readout">
						<dt>Field operation</dt>
						<dd>Active</dd>
					</div>
				</dl>

				<div class="hero-actions reveal" style="--d:4">
					<a href="#experience" class="btn btn--solid">View experience</a>
					<a href="#contact" class="btn btn--ghost">Get in touch →</a>
				</div>
			</div>

			<div class="metrics reveal" style="--d:5">
				<div class="metric">
					<span class="metric-num">10+</span>
					<span class="metric-label">Years in<br />production</span>
				</div>
				<div class="metric">
					<span class="metric-num">06</span>
					<span class="metric-label">Companies<br />shipped with</span>
				</div>
				<div class="metric">
					<span class="metric-num">07</span>
					<span class="metric-label">Industries<br />delivered for</span>
				</div>
				<div class="metric">
					<span class="metric-num">05</span>
					<span class="metric-label">Open-source<br />side projects</span>
				</div>
			</div>
		</section>

		<div class="marquee" tabindex="0" aria-label={`Frontend stack: ${marqueeItems.join(' ')}`}>
			<div class="marquee-track">
				<div class="marquee-group" aria-hidden="true">
					{marqueeItems.map((item) => <span>{item}</span>)}
				</div>
				<div class="marquee-group" aria-hidden="true">
					{marqueeItems.map((item) => <span>{item}</span>)}
				</div>
			</div>
		</div>

		<section class="section" id="experience">
			<div class="section-head">
				<span class="section-num">01</span>
				<h2 class="section-title">Experience</h2>
				<p class="section-desc">
					10+ years delivering production frontend systems with product, backend, and design teams in agile environments.
				</p>
			</div>

			<div class="cases">
				{experience.map((item) => (
					<article class="case reveal">
						<div class="case-meta">
							<span class="case-tag">{item.tag}</span>
							<span class="case-year">{item.year}</span>
						</div>
						<h3 class="case-title">{item.title}</h3>
						<p class="case-role">{item.role}</p>
							<span class={`case-status${item.year.includes('Present') ? ' is-active' : ''}`} aria-hidden="true">{item.year.includes('Present') ? 'ACTIVE' : 'ARCHIVED'}</span>
						<p class="case-text">{item.text}</p>
						<div class="case-stack">
							{item.stack.map((stackItem) => <span>{stackItem}</span>)}
						</div>
					</article>
				))}
			</div>
		</section>

		<section class="section section--alt" id="projects">
			<div class="section-head">
				<span class="section-num">02</span>
				<h2 class="section-title">Side projects</h2>
				<p class="section-desc">Side projects arranged as compact build studies.</p>
			</div>

			<div class="cases">
				{sideProjects.map((project) => (
					<article class="case reveal">
						<div class="case-meta">
							<span class="case-tag">{project.tag}</span>
							<a class="case-year" href={project.link} target="_blank" rel="noopener">Open GitHub ↗</a>
						</div>
						<h3 class="case-title">{project.title}</h3>
						<p class="case-text">{project.text}</p>
						<div class="case-stack">
							{project.stack.map((stackItem) => <span>{stackItem}</span>)}
						</div>
					</article>
				))}
			</div>
		</section>

		<section class="section" id="systems">
			<div class="section-head">
				<span class="section-num">03</span>
				<h2 class="section-title">Systems</h2>
				<p class="section-desc">
					Technical toolkit for scalable frontend delivery — component architecture, state management,
					performance, testing, and developer experience.
				</p>
			</div>

			<div class="systems">
				{systems.map((item) => (
					<div class="sys reveal">
						<span class="sys-num">{item.label}</span>
						<p>{item.value}</p>
					</div>
				))}
			</div>
		</section>

		<section class="section section--alt" id="about">
			<div class="section-head">
				<span class="section-num">04</span>
				<h2 class="section-title">About</h2>
			</div>
			<div class="about">
				<p class="about-lead reveal">
					I build <em>maintainable, scalable, production-grade</em> web applications — working at the
					interface between product, backend, and design to ship frontend systems that last.
				</p>
				<div class="about-grid">
					{aboutItems.map((item) => (
						<div class="about-item reveal">
							<span class="about-label">{item.label}</span>
							<p>{item.text}</p>
						</div>
					))}
				</div>
			</div>
		</section>

		<section class="section section--contact" id="contact">
			<div class="section-head">
				<span class="section-num">05</span>
				<h2 class="section-title">Let's build something</h2>
			</div>
			<p class="contact-lead reveal">
				Open to frontend roles, architecture-heavy product work, and teams that care
				about building maintainable and usable systems.
			</p>
			<a
				href="mailto:kontakt@michal-lach.pl"
				class="contact-mail reveal"
				data-copy-email="kontakt@michal-lach.pl"
				aria-label="Copy email address kontakt@michal-lach.pl"
				aria-live="polite"
			>
				kontakt@michal-lach.pl
			</a>
			<div class="contact-links reveal">
				<a href="https://github.com/padsbanger" target="_blank" rel="noopener">GitHub ↗</a>
				<a href="https://www.linkedin.com/in/micha%C5%82-lach-98854a6b/" target="_blank" rel="noopener">LinkedIn ↗</a>
				<a href="mailto:kontakt@michal-lach.pl">Email ↗</a>
				<a href="/cv.pdf" target="_blank" rel="noopener">Download CV ↗</a>
			</div>
		</section>
	</main>

	<footer class="site-footer">
		<span class="sys-meta">
			<a href="view-source:https://michal-lach.pl/" data-view-source>view-source</a>
			<span>ml.system --version 1.0.0</span>
			<span>uptime <span id="sys-uptime">00:00:00</span></span>
		</span>
		<span>Michał Lach, frontend engineering · all work is my own</span>
		<span class="sys-status" id="sys-status" aria-hidden="true">GDYNIA <span class="sys-clock" id="sys-clock">··:··:··</span> CET</span>
		<a href="#top">Back to top ↑</a>
	</footer>
</Layout>

<script src="../scripts/home.ts"></script>
