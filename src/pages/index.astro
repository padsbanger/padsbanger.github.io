---
import Layout from '../layouts/Layout.astro';

const featuredProjects = [
	{
		code: 'A-01',
		title: 'Constellation Archive',
		type: 'Portfolio platform',
		description:
			'Case studies, narrative project pages, and modular content structures presented through a clean command-interface layout.',
		stats: ['Astro', 'Content systems', 'UI direction'],
	},
	{
		code: 'B-12',
		title: 'Frontier Relay',
		type: 'Launch page system',
		description:
			'A reusable frontend framework for product pages that need a premium tone, fast performance, and confident information hierarchy.',
		stats: ['Responsive UI', 'Design systems', 'Build delivery'],
	},
	{
		code: 'C-07',
		title: 'Surveyor Frame',
		type: 'Brand redesign',
		description:
			'An interface refresh focused on orientation, visual discipline, and presenting dense information with calm futuristic structure.',
		stats: ['Narrative UX', 'Art direction', 'Frontend engineering'],
	},
];

const systems = [
	{ label: 'Navigation', value: 'Clear hierarchy and high-legibility HUD structure' },
	{ label: 'Motion', value: 'Soft transitions, restrained emphasis, no wasted movement' },
	{ label: 'Build', value: 'Astro, React, modern CSS, reusable components' },
	{ label: 'Delivery', value: 'Fast pages, responsive layouts, production-ready code' },
];
---

<Layout
	title="Pads Banger | Interface Portfolio"
	description="A frontend portfolio styled like a deep-space command interface with HUD panels, telemetry framing, and in-game sci-fi menu energy."
>
	<div class="three-backdrop" id="three-backdrop" aria-hidden="true"></div>
	<main class="shell">
		<header class="topbar intro-reveal">
			<div class="brand">
				<div class="brand-emblem">
					<span></span>
				</div>
				<div>
					<p class="label">Pads Banger</p>
					<p class="subtle">Frontend systems / interface direction / visual engineering</p>
				</div>
			</div>

			<nav class="nav-tabs" aria-label="Primary">
				<a class="is-active" href="#overview">Overview</a>
				<a href="#missions">Missions</a>
				<a href="#systems">Systems</a>
				<a href="#contact">Contact</a>
			</nav>
		</header>

		<section class="command-frame panel" id="overview">
			<div class="frame-header intro-reveal">
				<div class="header-block">
					<p class="label">Operator</p>
					<strong>Pads Banger</strong>
				</div>
				<div class="header-block">
					<p class="label">Status</p>
					<strong>Available for frontend commissions</strong>
				</div>
				<div class="header-block">
					<p class="label">Region</p>
					<strong>Web / portfolio / launch systems</strong>
				</div>
			</div>

			<div class="frame-body">
				<div class="hero-copy intro-reveal">
					<p class="eyebrow">Navigation Summary</p>
					<h1>Designing websites that feel like navigable systems, not decorative pages.</h1>
					<p class="lede">
						I build frontend experiences with clear structure, precise pacing, and a premium
						sci-fi interface language. The focus is on orientation, readability, and atmosphere
						without clutter.
					</p>
					<div class="action-row">
						<a class="button-primary" href="#missions">Open Mission Log</a>
						<a class="button-secondary" href="#contact">Transmit Inquiry</a>
					</div>
				</div>

				<div class="scanner-panel">
					<div class="scanner-graphic scanner-boot" id="scanner-graphic">
						<div class="ring ring-1"></div>
						<div class="ring ring-2"></div>
						<div class="ring ring-3"></div>
						<div class="axis axis-h"></div>
						<div class="axis axis-v"></div>
						<div class="scanner-boot-overlay" id="scanner-boot-overlay" aria-live="polite">
							<p class="scanner-boot-label">Navigation Boot</p>
							<p class="scanner-boot-status" id="scanner-boot-status">Initializing stellar map</p>
							<div class="scanner-boot-bar">
								<span class="scanner-boot-fill"></span>
							</div>
						</div>
						<div class="scanner-event-layer" aria-hidden="true">
							<div class="signal-line" id="signal-line"></div>
							<div class="scanner-comet" id="scanner-comet">
								<span class="scanner-comet-tail"></span>
								<span class="scanner-comet-core"></span>
							</div>
							<div class="scanner-disturbance" id="scanner-disturbance"></div>
						</div>
						<button class="sun-core scanner-target" type="button" data-target="sun" aria-label="Activate sun"></button>
						<button class="node node-1 scanner-target" type="button" data-target="aurelia" aria-label="Activate planet Aurelia"></button>
						<button class="node node-2 scanner-target" type="button" data-target="vesper" aria-label="Activate planet Vesper"></button>
						<button class="node node-3 scanner-target" type="button" data-target="khepri" aria-label="Activate planet Khepri"></button>
						<div class="scan-line"></div>
					</div>
					<div class="scanner-readout intro-reveal">
						<div>
							<p class="label">Discipline</p>
							<strong>Frontend design-engineering</strong>
						</div>
						<div>
							<p class="label">Stack</p>
							<strong>Astro / React / CSS</strong>
						</div>
						<div>
							<p class="label">Priority</p>
							<strong>Elegant, fast, production-ready interfaces</strong>
						</div>
					</div>
				</div>
			</div>
		</section>

		<section class="overview-grid intro-reveal">
			<article class="panel info-panel">
				<p class="label">Profile</p>
				<p>Portfolio sites, brand pages, and interface-heavy experiences with calm futuristic structure.</p>
			</article>
			<article class="panel info-panel">
				<p class="label">Visual Language</p>
				<p>Fine rules, circular diagrams, segmented modules, high legibility, and restrained glow.</p>
			</article>
			<article class="panel info-panel">
				<p class="label">Build Standard</p>
				<p>Responsive systems, maintainable code, clear content hierarchy, and controlled motion.</p>
			</article>
		</section>

		<section class="section-head intro-reveal" id="missions">
			<p class="eyebrow">Mission Log</p>
			<h2>Selected projects displayed like active records in a navigation console.</h2>
		</section>

		<section class="mission-grid intro-reveal">
			{featuredProjects.map((project) => (
				<article class="panel mission-card">
					<div class="mission-top">
						<span class="mission-code">{project.code}</span>
						<span class="mission-type">{project.type}</span>
					</div>
					<h3>{project.title}</h3>
					<p>{project.description}</p>
					<div class="stat-row">
						{project.stats.map((stat) => (
							<span>{stat}</span>
						))}
					</div>
					<a class="text-link" href="#contact">Open channel</a>
				</article>
			))}
		</section>

		<section class="systems-layout intro-reveal" id="systems">
			<div class="section-head compact">
				<p class="eyebrow">Systems</p>
				<h2>Every layer should help the user know where they are and what matters.</h2>
				<p class="lede compact-text">
					The style is interface-first: flatter surfaces, clearer segmentation, stronger data
					labeling, and less decorative drama. It feels closer to a ship menu than a marketing
					landing page.
				</p>
			</div>

			<div class="panel systems-panel">
				{systems.map((item) => (
					<div class="system-row">
						<p class="label">{item.label}</p>
						<strong>{item.value}</strong>
					</div>
				))}
			</div>
		</section>

		<section class="panel contact-panel intro-reveal" id="contact">
			<div>
				<p class="eyebrow">Contact Uplink</p>
				<h2>Ready to build something that feels like a real interface?</h2>
			</div>
			<div class="contact-meta">
				<div class="contact-links">
					<a class="button-primary" href="mailto:hello@padsbanger.com">Email</a>
					<a class="button-secondary" href="https://github.com/padsbanger" target="_blank" rel="noreferrer">GitHub</a>
					<a class="button-secondary" href="https://www.linkedin.com/in/michal-lach/" target="_blank" rel="noreferrer">LinkedIn</a>
				</div>
				<p class="subtle">`mailto:hello@padsbanger.com` / `github.com/padsbanger` / `linkedin.com/in/michal-lach/`</p>
			</div>
		</section>
	</main>
</Layout>

<style>
	:global(body)::before {
		content: '';
		position: fixed;
		inset: 0;
		pointer-events: none;
		background-image:
			linear-gradient(rgba(255, 255, 255, 0.022) 1px, transparent 1px),
			linear-gradient(90deg, rgba(255, 255, 255, 0.022) 1px, transparent 1px);
		background-size: 48px 48px;
		opacity: 0.18;
	}

	:global(body)::after {
		content: '';
		position: fixed;
		inset: 0;
		pointer-events: none;
		background:
			radial-gradient(circle at center, rgba(123, 156, 212, 0.1), transparent 30%),
			linear-gradient(180deg, rgba(255, 255, 255, 0.015), transparent 20%);
	}

	.shell {
		width: min(1200px, calc(100% - 2rem));
		margin: 0 auto;
		padding: 1rem 0 2.5rem;
		position: relative;
		z-index: 1;
	}

	.three-backdrop {
		position: fixed;
		inset: 0;
		z-index: 0;
		pointer-events: none;
		opacity: 0.7;
	}

	.three-backdrop canvas {
		display: block;
		width: 100%;
		height: 100%;
	}

	.intro-reveal {
		opacity: 0;
		transform: translateY(18px);
		animation: interface-reveal 680ms cubic-bezier(0.22, 1, 0.36, 1) forwards;
		animation-delay: 1.15s;
	}

	.topbar,
	.overview-grid,
	.mission-grid,
	.systems-layout,
	.contact-panel {
		animation: lift-in 600ms ease both;
	}

	.topbar {
		display: flex;
		justify-content: space-between;
		align-items: center;
		gap: 1rem;
		margin-bottom: 1rem;
	}

	.brand {
		display: flex;
		align-items: center;
		gap: 0.9rem;
	}

	.brand-emblem {
		position: relative;
		width: 2.85rem;
		height: 2.85rem;
		border: 1px solid rgba(191, 210, 245, 0.35);
		border-radius: 50%;
	}

	.brand-emblem::before,
	.brand-emblem::after,
	.brand-emblem span {
		content: '';
		position: absolute;
		border-radius: 50%;
	}

	.brand-emblem::before {
		inset: 0.34rem;
		border: 1px solid rgba(191, 210, 245, 0.18);
	}

	.brand-emblem::after {
		width: 0.34rem;
		height: 0.34rem;
		top: 0.28rem;
		left: 50%;
		transform: translateX(-50%);
		background: #dce7fa;
		box-shadow: 0 0 14px rgba(220, 231, 250, 0.5);
	}

	.brand-emblem span {
		width: 0.56rem;
		height: 0.56rem;
		top: 50%;
		left: 50%;
		transform: translate(-50%, -50%);
		background: #edf3ff;
	}

	.label,
	.eyebrow,
	.subtle,
	.mission-code,
	.mission-type,
	.stat-row span,
	.nav-tabs a {
		margin: 0;
		text-transform: uppercase;
		letter-spacing: 0.16em;
	}

	.label,
	.eyebrow {
		font-size: 0.7rem;
		color: #9fb3d7;
	}

	.subtle,
	.mission-type,
	.stat-row span {
		font-size: 0.72rem;
		color: rgba(237, 243, 255, 0.62);
	}

	.nav-tabs {
		display: flex;
		flex-wrap: wrap;
		gap: 0.6rem;
	}

	.nav-tabs a {
		padding: 0.72rem 1rem;
		border: 1px solid rgba(191, 210, 245, 0.12);
		border-radius: 999px;
		text-decoration: none;
		font-size: 0.7rem;
		color: rgba(237, 243, 255, 0.78);
		background: rgba(255, 255, 255, 0.02);
	}

	.nav-tabs a.is-active {
		border-color: rgba(191, 210, 245, 0.32);
		background: rgba(191, 210, 245, 0.09);
		color: #edf3ff;
	}

	.panel {
		position: relative;
		border: 1px solid rgba(191, 210, 245, 0.12);
		border-radius: 1.2rem;
		background: linear-gradient(180deg, rgba(8, 14, 24, 0.96), rgba(8, 14, 24, 0.9));
		overflow: hidden;
	}

	.panel::before {
		content: '';
		position: absolute;
		inset: 0.85rem;
		border: 1px solid rgba(191, 210, 245, 0.05);
		border-radius: 0.8rem;
		pointer-events: none;
	}

	.command-frame {
		padding: 1.1rem;
		margin-bottom: 1rem;
	}

	.frame-header {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 1px;
		margin-bottom: 1rem;
		background: rgba(191, 210, 245, 0.09);
	}

	.header-block {
		padding: 0.9rem 1rem;
		background: rgba(12, 18, 30, 0.98);
	}

	.frame-header strong,
	.scanner-readout strong,
	.system-row strong {
		display: block;
		margin-top: 0.45rem;
		font-size: 0.95rem;
		line-height: 1.5;
		font-weight: 500;
	}

	.frame-body {
		display: grid;
		grid-template-columns: minmax(0, 1.2fr) minmax(320px, 0.9fr);
		gap: 1rem;
		align-items: stretch;
	}

	h1,
	h2,
	h3,
	p {
		margin-top: 0;
	}

	h1 {
		font-size: clamp(2.8rem, 6vw, 5.2rem);
		line-height: 0.98;
		font-weight: 500;
		max-width: 12ch;
		margin: 1.5rem 0;
	}

	h2 {
		font-size: clamp(1.85rem, 3.6vw, 3rem);
		line-height: 1.05;
		font-weight: 500;
		max-width: 15ch;
		margin: 1.5rem 0;
	}

	h3 {
		font-size: 1.3rem;
		font-weight: 500;
		margin: 1.5rem 0;
	}

	.lede,
	.info-panel p,
	.mission-card p,
	.compact-text,
	.contact-meta p {
		font-size: 0.98rem;
		line-height: 1.75;
		color: rgba(237, 243, 255, 0.86);
	}

	.hero-copy {
		padding: 1.2rem;
	}

	.action-row,
	.contact-meta {
		display: flex;
		flex-wrap: wrap;
		gap: 0.8rem;
		align-items: center;
	}

	.contact-links {
		display: flex;
		flex-wrap: wrap;
		gap: 0.8rem;
	}

	.button-primary,
	.button-secondary {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		min-height: 3rem;
		padding: 0.82rem 1.2rem;
		border-radius: 999px;
		text-decoration: none;
		text-transform: uppercase;
		letter-spacing: 0.14em;
		font-size: 0.72rem;
	}

	.button-primary {
		background: #dce7fa;
		color: #07101b;
		font-weight: 700;
	}

	.button-secondary {
		border: 1px solid rgba(191, 210, 245, 0.18);
		background: rgba(255, 255, 255, 0.03);
		color: #edf3ff;
	}

	.scanner-panel {
		display: grid;
		grid-template-rows: auto auto;
		gap: 1rem;
		padding: 1.2rem;
	}

	.scanner-graphic {
		position: relative;
		min-height: 24rem;
		border: 1px solid rgba(191, 210, 245, 0.12);
		border-radius: 1rem;
		background:
			radial-gradient(circle at center, rgba(191, 210, 245, 0.08), transparent 38%),
			linear-gradient(180deg, rgba(255, 255, 255, 0.015), rgba(255, 255, 255, 0.01));
		overflow: hidden;
	}

	.scanner-graphic.is-booting .scanner-target {
		pointer-events: none;
	}

	.scanner-graphic.is-booting .sun-core,
	.scanner-graphic.is-booting .node {
		opacity: 0;
	}

	.scanner-boot {
		opacity: 0;
		transform: scale(0.94);
		animation: scanner-boot 900ms cubic-bezier(0.16, 1, 0.3, 1) 120ms forwards;
	}

	.scanner-boot-overlay {
		position: absolute;
		inset: 1rem;
		z-index: 5;
		display: grid;
		align-content: end;
		gap: 0.55rem;
		padding: 1rem;
		border: 1px solid rgba(191, 210, 245, 0.1);
		border-radius: 0.8rem;
		background:
			linear-gradient(180deg, rgba(8, 14, 24, 0.1), rgba(8, 14, 24, 0.74) 52%, rgba(8, 14, 24, 0.92)),
			radial-gradient(circle at center, rgba(191, 210, 245, 0.08), transparent 45%);
		backdrop-filter: blur(3px);
		transition:
			opacity 420ms ease,
			transform 420ms ease;
	}

	.scanner-boot-overlay.is-hidden {
		opacity: 0;
		transform: translateY(10px);
		pointer-events: none;
	}

	.scanner-boot-label,
	.scanner-boot-status {
		margin: 0;
		text-transform: uppercase;
		letter-spacing: 0.16em;
	}

	.scanner-boot-label {
		font-size: 0.68rem;
		color: rgba(159, 179, 215, 0.9);
	}

	.scanner-boot-status {
		font-size: 0.82rem;
		color: rgba(237, 243, 255, 0.9);
	}

	.scanner-boot-bar {
		height: 0.32rem;
		border-radius: 999px;
		background: rgba(191, 210, 245, 0.12);
		overflow: hidden;
	}

	.scanner-boot-fill {
		display: block;
		height: 100%;
		width: 100%;
		transform-origin: left center;
		transform: scaleX(0);
		background: linear-gradient(90deg, rgba(191, 210, 245, 0.38), rgba(246, 212, 143, 0.95));
		box-shadow: 0 0 16px rgba(246, 212, 143, 0.35);
		animation: boot-progress 1.08s cubic-bezier(0.2, 1, 0.28, 1) 180ms forwards;
	}

	.scanner-target {
		padding: 0;
		border: 0;
		cursor: pointer;
		background: transparent;
	}

	.scanner-event-layer {
		position: absolute;
		inset: 0;
		z-index: 2;
		pointer-events: none;
	}

	.ring,
	.axis,
	.sun-core,
	.node,
	.scan-line {
		position: absolute;
	}

	.ring {
		left: 50%;
		top: 50%;
		transform: translate(-50%, -50%);
		border: 1px solid rgba(191, 210, 245, 0.18);
		border-radius: 50%;
		z-index: 1;
	}

	.ring-1 {
		width: 18rem;
		height: 18rem;
	}

	.ring-2 {
		width: 12rem;
		height: 12rem;
	}

	.ring-3 {
		width: 6rem;
		height: 6rem;
	}

	.axis-h {
		left: 2rem;
		right: 2rem;
		top: 50%;
		height: 1px;
		background: rgba(191, 210, 245, 0.12);
		z-index: 1;
	}

	.axis-v {
		top: 2rem;
		bottom: 2rem;
		left: 50%;
		width: 1px;
		background: rgba(191, 210, 245, 0.12);
		z-index: 1;
	}

	.sun-core {
		left: 50%;
		top: 50%;
		width: 1.8rem;
		height: 1.8rem;
		border-radius: 50%;
		background: radial-gradient(circle, #fff7dc 0%, #f6d48f 45%, #b98a46 100%);
		box-shadow:
			0 0 24px rgba(246, 212, 143, 0.95),
			0 0 54px rgba(246, 212, 143, 0.52),
			0 0 90px rgba(246, 212, 143, 0.24);
		transform: translate(-50%, -50%);
		animation: sun-pulse 4.2s ease-in-out infinite;
		z-index: 3;
		transition: opacity 280ms ease;
	}

	.sun-core:hover,
	.sun-core:focus-visible,
	.node:hover,
	.node:focus-visible {
		outline: none;
		filter: brightness(1.15);
	}

	.scanner-target:hover,
	.scanner-target:focus-visible {
		outline: none;
		filter: brightness(1.15);
	}

	.scanner-target.is-activated {
		animation: marker-activate 900ms ease-in-out;
	}

	.sun-core.is-activated {
		animation:
			sun-pulse 4.2s ease-in-out infinite,
			sun-activate 900ms ease-in-out;
	}

	.sun-core.is-flaring {
		animation: sun-pulse 4.2s ease-in-out infinite;
	}

	.sun-core::before,
	.sun-core::after {
		content: '';
		position: absolute;
		left: 50%;
		top: 50%;
		border-radius: 50%;
		transform: translate(-50%, -50%);
	}

	.sun-core::before {
		width: 3.4rem;
		height: 3.4rem;
		border: 1px solid rgba(246, 212, 143, 0.28);
	}

	.sun-core::after {
		width: 6rem;
		height: 6rem;
		background: radial-gradient(circle, rgba(246, 212, 143, 0.26), transparent 72%);
	}

	.sun-core.is-flaring::after {
		animation: sun-flare-burst 1.45s ease-out;
	}

	.node {
		--orbit-size: 18rem;
		--orbit-duration: 18s;
		--orbit-angle: 0deg;
		width: 0.55rem;
		height: 0.55rem;
		border-radius: 50%;
		background: #dce7fa;
		box-shadow: 0 0 12px rgba(220, 231, 250, 0.5);
		left: 50%;
		top: 50%;
		transform:
			translate(-50%, -50%)
			rotate(var(--orbit-angle))
			translateX(calc(var(--orbit-size) / 2))
			rotate(calc(var(--orbit-angle) * -1));
		animation: orbit-spin var(--orbit-duration) linear infinite;
		z-index: 2;
		transition:
			box-shadow 180ms ease,
			opacity 280ms ease;
	}

	.node.is-activated {
		animation:
			orbit-spin var(--orbit-duration) linear infinite,
			planet-activate 900ms ease-in-out;
		box-shadow:
			0 0 0 0.18rem rgba(220, 231, 250, 0.12),
			0 0 18px rgba(220, 231, 250, 0.8);
	}

	.node::after {
		content: '';
		position: absolute;
		left: 50%;
		top: 50%;
		width: 0.8rem;
		height: 0.8rem;
		border-radius: 50%;
		border: 1px solid rgba(220, 231, 250, 0.55);
		transform: translate(-50%, -50%) scale(0.4);
		opacity: 0;
		pointer-events: none;
	}

	.node.is-pulsing::after {
		animation: orbit-pulse 1.15s ease-out;
