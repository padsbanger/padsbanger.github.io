---
import Layout from '../layouts/Layout.astro';

import '../styles/home.css';

const featuredProjects = [
	{
		code: 'N-24',
		title: 'Nordea',
		type: 'Senior Frontend Engineer / May 2024 - Present',
		description:
			'Developing internal platforms for API onboarding, enterprise services, secure AI access management, and Redis tooling across engineering teams.',
		stats: ['Enterprise platforms', 'AI tooling', 'Security'],
	},
	{
		code: 'M-20',
		title: 'MasterBorn',
		type: 'Frontend / Lead Frontend Engineer / Aug 2020 - Apr 2024',
		description:
			'Led React and TypeScript frontend work for payment processing, sports video streaming, cycling analytics, and medical device inspection workflows.',
		stats: ['React', 'TypeScript', 'Architecture'],
	},
	{
		code: 'J-19',
		title: 'JIT Team',
		type: 'Frontend Engineer / Feb 2019 - Jul 2020',
		description:
			'Built hybrid PWA applications for ship inspection processes and frontend systems for smart city and IoT management platforms.',
		stats: ['PWA', 'IoT', 'Inspection tools'],
	},
	{
		code: 'S-16',
		title: 'Schibsted Tech Polska',
		type: 'UI Developer / Lead Frontend Developer / Jul 2016 - Jan 2019',
		description:
			'Led frontend development for booking and marketplace platforms, recommendation features, and reusable component architecture.',
		stats: ['Marketplaces', 'Components', 'Leadership'],
	},
	{
		code: 'E-15',
		title: 'EPAM Systems',
		type: 'UI Software Developer / May 2015 - Jun 2016',
		description:
			'Worked on internal enterprise frontend projects, performed code reviews, and contributed to shared development standards.',
		stats: ['Enterprise UI', 'Reviews', 'Standards'],
	},
	{
		code: 'M-13',
		title: 'Misys',
		type: 'Software Developer / Aug 2013 - Apr 2015',
		description:
			'Developed frontend features for financial risk analysis software, maintained cross-browser compatibility, and introduced end-to-end testing practices.',
		stats: ['Fintech', 'E2E testing', 'Compatibility'],
	},
];

const systems = [
	{ label: 'Frontend', value: 'React, Next.js, TypeScript, JavaScript, HTML5, CSS3' },
	{ label: 'State', value: 'Redux Toolkit, Zustand, MobX, Context API, RTK Query' },
	{ label: 'APIs', value: 'REST, GraphQL, Apollo Client, Axios, Fetch' },
	{ label: 'Styling', value: 'Tailwind CSS, Styled Components, Emotion, CSS Modules, Sass' },
	{ label: 'Testing', value: 'Jest, React Testing Library, Vitest, Protractor' },
	{ label: 'Tooling', value: 'Vite, Webpack, Docker, Git, GitHub, Jenkins, TeamCity' },
	{ label: 'AI', value: 'Ollama, Copilot, vLLM, ollama.cpp' },
	
];
---

<Layout
	title="Michal Lach | Senior Frontend Engineer"
	description="Senior Frontend Engineer based in Gdansk, Poland, specializing in React, TypeScript, frontend architecture, design systems, and scalable web applications."
>
	<div class="three-backdrop" id="three-backdrop" aria-hidden="true"></div>
	<main class="shell">
		<header class="topbar intro-reveal">
			<div class="brand">
				<div class="brand-emblem">
					<span></span>
				</div>
				<div>
					<p class="label">Michal Lach</p>
					<p class="subtle">Frontend Engineer / React / TypeScript / architecture</p>
				</div>
			</div>

			<nav class="nav-tabs" aria-label="Primary">
				<a class="is-active" href="#overview">Overview</a>
				<a href="#missions">Experience</a>
				<a href="#systems">Systems</a>
				<a href="#contact">Contact</a>
			</nav>
		</header>

		<section class="command-frame panel" id="overview">
			<div class="frame-header intro-reveal">
				<div class="header-block">
					<p class="label">Operator</p>
					<strong>Michal Lach</strong>
				</div>
				<div class="header-block">
					<p class="label">Status</p>
					<strong>Frontend Engineer avaiable for forward deployment</strong>
				</div>
				<div class="header-block">
					<p class="label">Region</p>
					<strong>Gdynia, Poland / Earth / Sol System</strong>
				</div>
			</div>

			<div class="frame-body">
				<div class="hero-copy intro-reveal">
					<p class="eyebrow">Navigation Summary</p>
					<h1>Building scalable frontend systems for complex products.</h1>
					<p class="lede">
						Senior Frontend Engineer focused on React, TypeScript, performance optimization,
						component design systems, state management, and developer experience across fintech,
						AI, enterprise, healthcare, and media products.
					</p>
					<div class="action-row">
						<a class="button-primary" href="#missions">Open Experience Log</a>
						<a class="button-secondary" href="#contact">Contact</a>
					</div>
				</div>

				<div class="scanner-panel">
					<div class="scanner-graphic scanner-boot" id="scanner-graphic">
						<div class="scanner-three" id="scanner-three" aria-hidden="true"></div>
						<div class="ring ring-1"></div>
						<div class="ring ring-2"></div>
						<div class="ring ring-3"></div>
						<div class="axis axis-h"></div>
						<div class="axis axis-v"></div>
						<div class="scanner-boot-overlay" id="scanner-boot-overlay" aria-live="polite">
							<p class="scanner-boot-label">Navigation Boot</p>
							<p class="scanner-boot-status" id="scanner-boot-status">Initializing stellar map</p>
							<div class="scanner-boot-bar">
								<span class="scanner-boot-fill"></span>
							</div>
						</div>
						<div class="scanner-event-layer" aria-hidden="true">
							<div class="signal-line" id="signal-line"></div>
							<div class="scanner-comet" id="scanner-comet">
								<span class="scanner-comet-tail"></span>
								<span class="scanner-comet-core"></span>
							</div>
							<div class="scanner-disturbance" id="scanner-disturbance"></div>
						</div>
						<button class="sun-core scanner-target" type="button" data-target="sun" aria-label="Activate sun"></button>
						<button class="node node-1 scanner-target" type="button" data-target="aurelia" aria-label="Activate planet Aurelia"></button>
						<button class="node node-2 scanner-target" type="button" data-target="vesper" aria-label="Activate planet Vesper"></button>
						<button class="node node-3 scanner-target" type="button" data-target="khepri" aria-label="Activate planet Khepri"></button>
						<div class="scan-line"></div>
					</div>
					<div class="scanner-readout intro-reveal">
						<div>
							<p class="label">Discipline</p>
							<strong>Frontend architecture and product engineering</strong>
						</div>
						<div>
							<p class="label">Stack</p>
							<strong>React / Next.js / TypeScript / modern CSS</strong>
						</div>
						<div>
							<p class="label">Priority</p>
							<strong>Maintainable, scalable, production-grade web applications</strong>
						</div>
					</div>
				</div>
			</div>
		</section>

		<section class="overview-grid intro-reveal">
			<article class="panel info-panel">
				<p class="label">Profile</p>
				<p>10+ years delivering production frontend systems with product, backend, and design teams in agile environments.</p>
			</article>
			<article class="panel info-panel">
				<p class="label">Industries</p>
				<p>Fintech, AI platforms, enterprise tooling, healthcare workflows, media products, IoT, and smart city systems.</p>
			</article>
			<article class="panel info-panel">
				<p class="label">Education</p>
				<p>Bachelor's Degree in Information Technology, plus Cambridge First Certificate in English at B2 level.</p>
			</article>
		</section>

		<section class="section-head intro-reveal" id="missions">
			<p class="eyebrow">Experience Log</p>
			<h2>Professional roles mapped as active records in a navigation console.</h2>
		</section>

		<section class="mission-grid intro-reveal">
			{featuredProjects.map((project) => (
				<article class="panel mission-card">
					<div class="mission-top">
						<span class="mission-code">{project.code}</span>
						<span class="mission-type">{project.type}</span>
					</div>
					<h3>{project.title}</h3>
					<p>{project.description}</p>
					<div class="stat-row">
						{project.stats.map((stat) => (
							<span>{stat}</span>
						))}
					</div>
					<a class="text-link" href="#contact">Open channel</a>
				</article>
			))}
		</section>

		<section class="systems-layout intro-reveal" id="systems">
			<div class="section-head compact">
				<p class="eyebrow">Systems</p>
				<h2>Technical toolkit for scalable frontend delivery.</h2>
				<p class="lede compact-text">
					Strong focus on component architecture, state management, performance, testing,
					developer experience, and collaboration across design and engineering workflows.
				</p>
			</div>

			<div class="panel systems-panel">
				{systems.map((item) => (
					<div class="system-row">
						<p class="label">{item.label}</p>
						<strong>{item.value}</strong>
					</div>
				))}
			</div>
		</section>

		<section class="panel contact-panel intro-reveal" id="contact">
			<div>
				<p class="eyebrow">Contact Uplink</p>
				<h2>Available for frontend engineering conversations.</h2>
			</div>
			<div class="contact-meta">
				<div class="contact-links">
					<a class="button-primary" href="mailto:kontakt@michal-lach.pl">Email</a>
					<a class="button-secondary" href="https://michal-lach.pl" target="_blank" rel="noreferrer">Website</a>
					<a class="button-secondary" href="https://github.com/padsbanger" target="_blank" rel="noreferrer">GitHub</a>
					<a class="button-secondary" href="https://www.linkedin.com/in/michal-lach/" target="_blank" rel="noreferrer">LinkedIn</a>
				</div>
				<p class="subtle">`kontakt@michal-lach.pl` / `michal-lach.pl` / `github.com/padsbanger` / `linkedin.com/in/michal-lach/`</p>
			</div>
		</section>
	</main>
</Layout>

<script src="../scripts/home.js"></script>
