---
import Layout from '../layouts/Layout.astro';

const featuredProjects = [
	{
		code: 'A-01',
		title: 'Constellation Archive',
		type: 'Portfolio platform',
		description:
			'Case studies, narrative project pages, and modular content structures presented through a clean command-interface layout.',
		stats: ['Astro', 'Content systems', 'UI direction'],
	},
	{
		code: 'B-12',
		title: 'Frontier Relay',
		type: 'Launch page system',
		description:
			'A reusable frontend framework for product pages that need a premium tone, fast performance, and confident information hierarchy.',
		stats: ['Responsive UI', 'Design systems', 'Build delivery'],
	},
	{
		code: 'C-07',
		title: 'Surveyor Frame',
		type: 'Brand redesign',
		description:
			'An interface refresh focused on orientation, visual discipline, and presenting dense information with calm futuristic structure.',
		stats: ['Narrative UX', 'Art direction', 'Frontend engineering'],
	},
];

const systems = [
	{ label: 'Navigation', value: 'Clear hierarchy and high-legibility HUD structure' },
	{ label: 'Motion', value: 'Soft transitions, restrained emphasis, no wasted movement' },
	{ label: 'Build', value: 'Astro, React, modern CSS, reusable components' },
	{ label: 'Delivery', value: 'Fast pages, responsive layouts, production-ready code' },
];
---

<Layout
	title="Pads Banger | Interface Portfolio"
	description="A frontend portfolio styled like a deep-space command interface with HUD panels, telemetry framing, and in-game sci-fi menu energy."
>
	<div class="three-backdrop" id="three-backdrop" aria-hidden="true"></div>
	<main class="shell">
		<header class="topbar intro-reveal">
			<div class="brand">
				<div class="brand-emblem">
					<span></span>
				</div>
				<div>
					<p class="label">Pads Banger</p>
					<p class="subtle">Frontend systems / interface direction / visual engineering</p>
				</div>
			</div>

			<nav class="nav-tabs" aria-label="Primary">
				<a class="is-active" href="#overview">Overview</a>
				<a href="#missions">Missions</a>
				<a href="#systems">Systems</a>
				<a href="#contact">Contact</a>
			</nav>
		</header>

		<section class="command-frame panel" id="overview">
			<div class="frame-header intro-reveal">
				<div class="header-block">
					<p class="label">Operator</p>
					<strong>Pads Banger</strong>
				</div>
				<div class="header-block">
					<p class="label">Status</p>
					<strong>Available for frontend commissions</strong>
				</div>
				<div class="header-block">
					<p class="label">Region</p>
					<strong>Web / portfolio / launch systems</strong>
				</div>
			</div>

			<div class="frame-body">
				<div class="hero-copy intro-reveal">
					<p class="eyebrow">Navigation Summary</p>
					<h1>Designing websites that feel like navigable systems, not decorative pages.</h1>
					<p class="lede">
						I build frontend experiences with clear structure, precise pacing, and a premium
						sci-fi interface language. The focus is on orientation, readability, and atmosphere
						without clutter.
					</p>
					<div class="action-row">
						<a class="button-primary" href="#missions">Open Mission Log</a>
						<a class="button-secondary" href="#contact">Transmit Inquiry</a>
					</div>
				</div>

				<div class="scanner-panel">
					<div class="scanner-graphic scanner-boot">
						<div class="ring ring-1"></div>
						<div class="ring ring-2"></div>
						<div class="ring ring-3"></div>
						<div class="axis axis-h"></div>
						<div class="axis axis-v"></div>
						<button class="sun-core scanner-target" type="button" aria-label="Activate sun"></button>
						<button class="node node-1 scanner-target" type="button" aria-label="Activate planet Aurelia"></button>
						<button class="node node-2 scanner-target" type="button" aria-label="Activate planet Vesper"></button>
						<button class="node node-3 scanner-target" type="button" aria-label="Activate planet Khepri"></button>
						<div class="scan-line"></div>
					</div>
					<div class="scanner-readout intro-reveal">
						<div>
							<p class="label">Discipline</p>
							<strong>Frontend design-engineering</strong>
						</div>
						<div>
							<p class="label">Stack</p>
							<strong>Astro / React / CSS</strong>
						</div>
						<div>
							<p class="label">Priority</p>
							<strong>Elegant, fast, production-ready interfaces</strong>
						</div>
					</div>
				</div>
			</div>
		</section>

		<section class="overview-grid intro-reveal">
			<article class="panel info-panel">
				<p class="label">Profile</p>
				<p>Portfolio sites, brand pages, and interface-heavy experiences with calm futuristic structure.</p>
			</article>
			<article class="panel info-panel">
				<p class="label">Visual Language</p>
				<p>Fine rules, circular diagrams, segmented modules, high legibility, and restrained glow.</p>
			</article>
			<article class="panel info-panel">
				<p class="label">Build Standard</p>
				<p>Responsive systems, maintainable code, clear content hierarchy, and controlled motion.</p>
			</article>
		</section>

		<section class="section-head intro-reveal" id="missions">
			<p class="eyebrow">Mission Log</p>
			<h2>Selected projects displayed like active records in a navigation console.</h2>
		</section>

		<section class="mission-grid intro-reveal">
			{featuredProjects.map((project) => (
				<article class="panel mission-card">
					<div class="mission-top">
						<span class="mission-code">{project.code}</span>
						<span class="mission-type">{project.type}</span>
					</div>
					<h3>{project.title}</h3>
					<p>{project.description}</p>
					<div class="stat-row">
						{project.stats.map((stat) => (
							<span>{stat}</span>
						))}
					</div>
					<a class="text-link" href="#contact">Open channel</a>
				</article>
			))}
		</section>

		<section class="systems-layout intro-reveal" id="systems">
			<div class="section-head compact">
				<p class="eyebrow">Systems</p>
				<h2>Every layer should help the user know where they are and what matters.</h2>
				<p class="lede compact-text">
					The style is interface-first: flatter surfaces, clearer segmentation, stronger data
					labeling, and less decorative drama. It feels closer to a ship menu than a marketing
					landing page.
				</p>
			</div>

			<div class="panel systems-panel">
				{systems.map((item) => (
					<div class="system-row">
						<p class="label">{item.label}</p>
						<strong>{item.value}</strong>
					</div>
				))}
			</div>
		</section>

		<section class="panel contact-panel intro-reveal" id="contact">
			<div>
				<p class="eyebrow">Contact Uplink</p>
				<h2>Ready to build something that feels like a real interface?</h2>
			</div>
			<div class="contact-meta">
				<div class="contact-links">
					<a class="button-primary" href="mailto:hello@padsbanger.com">Email</a>
					<a class="button-secondary" href="https://github.com/padsbanger" target="_blank" rel="noreferrer">GitHub</a>
					<a class="button-secondary" href="https://www.linkedin.com/in/michal-lach/" target="_blank" rel="noreferrer">LinkedIn</a>
				</div>
				<p class="subtle">`mailto:hello@padsbanger.com` / `github.com/padsbanger` / `linkedin.com/in/michal-lach/`</p>
			</div>
		</section>
	</main>
</Layout>

<style>
	:global(body)::before {
		content: '';
		position: fixed;
		inset: 0;
		pointer-events: none;
		background-image:
			linear-gradient(rgba(255, 255, 255, 0.022) 1px, transparent 1px),
			linear-gradient(90deg, rgba(255, 255, 255, 0.022) 1px, transparent 1px);
		background-size: 48px 48px;
		opacity: 0.18;
	}

	:global(body)::after {
		content: '';
		position: fixed;
		inset: 0;
		pointer-events: none;
		background:
			radial-gradient(circle at center, rgba(123, 156, 212, 0.1), transparent 30%),
			linear-gradient(180deg, rgba(255, 255, 255, 0.015), transparent 20%);
	}

	.shell {
		width: min(1200px, calc(100% - 2rem));
		margin: 0 auto;
		padding: 1rem 0 2.5rem;
		position: relative;
		z-index: 1;
	}

	.three-backdrop {
		position: fixed;
		inset: 0;
		z-index: 0;
		pointer-events: none;
		opacity: 0.7;
	}

	.three-backdrop canvas {
		display: block;
		width: 100%;
		height: 100%;
	}

	.intro-reveal {
		opacity: 0;
		transform: translateY(18px);
		animation: interface-reveal 680ms cubic-bezier(0.22, 1, 0.36, 1) forwards;
		animation-delay: 1.15s;
	}

	.topbar,
	.overview-grid,
	.mission-grid,
	.systems-layout,
	.contact-panel {
		animation: lift-in 600ms ease both;
	}

	.topbar {
		display: flex;
		justify-content: space-between;
		align-items: center;
		gap: 1rem;
		margin-bottom: 1rem;
	}

	.brand {
		display: flex;
		align-items: center;
		gap: 0.9rem;
	}

	.brand-emblem {
		position: relative;
		width: 2.85rem;
		height: 2.85rem;
		border: 1px solid rgba(191, 210, 245, 0.35);
		border-radius: 50%;
	}

	.brand-emblem::before,
	.brand-emblem::after,
	.brand-emblem span {
		content: '';
		position: absolute;
		border-radius: 50%;
	}

	.brand-emblem::before {
		inset: 0.34rem;
		border: 1px solid rgba(191, 210, 245, 0.18);
	}

	.brand-emblem::after {
		width: 0.34rem;
		height: 0.34rem;
		top: 0.28rem;
		left: 50%;
		transform: translateX(-50%);
		background: #dce7fa;
		box-shadow: 0 0 14px rgba(220, 231, 250, 0.5);
	}

	.brand-emblem span {
		width: 0.56rem;
		height: 0.56rem;
		top: 50%;
		left: 50%;
		transform: translate(-50%, -50%);
		background: #edf3ff;
	}

	.label,
	.eyebrow,
	.subtle,
	.mission-code,
	.mission-type,
	.stat-row span,
	.nav-tabs a {
		margin: 0;
		text-transform: uppercase;
		letter-spacing: 0.16em;
	}

	.label,
	.eyebrow {
		font-size: 0.7rem;
		color: #9fb3d7;
	}

	.subtle,
	.mission-type,
	.stat-row span {
		font-size: 0.72rem;
		color: rgba(237, 243, 255, 0.62);
	}

	.nav-tabs {
		display: flex;
		flex-wrap: wrap;
		gap: 0.6rem;
	}

	.nav-tabs a {
		padding: 0.72rem 1rem;
		border: 1px solid rgba(191, 210, 245, 0.12);
		border-radius: 999px;
		text-decoration: none;
		font-size: 0.7rem;
		color: rgba(237, 243, 255, 0.78);
		background: rgba(255, 255, 255, 0.02);
	}

	.nav-tabs a.is-active {
		border-color: rgba(191, 210, 245, 0.32);
		background: rgba(191, 210, 245, 0.09);
		color: #edf3ff;
	}

	.panel {
		position: relative;
		border: 1px solid rgba(191, 210, 245, 0.12);
		border-radius: 1.2rem;
		background: linear-gradient(180deg, rgba(8, 14, 24, 0.96), rgba(8, 14, 24, 0.9));
		overflow: hidden;
	}

	.panel::before {
		content: '';
		position: absolute;
		inset: 0.85rem;
		border: 1px solid rgba(191, 210, 245, 0.05);
		border-radius: 0.8rem;
		pointer-events: none;
	}

	.command-frame {
		padding: 1.1rem;
		margin-bottom: 1rem;
	}

	.frame-header {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 1px;
		margin-bottom: 1rem;
		background: rgba(191, 210, 245, 0.09);
	}

	.header-block {
		padding: 0.9rem 1rem;
		background: rgba(12, 18, 30, 0.98);
	}

	.frame-header strong,
	.scanner-readout strong,
	.system-row strong {
		display: block;
		margin-top: 0.45rem;
		font-size: 0.95rem;
		line-height: 1.5;
		font-weight: 500;
	}

	.frame-body {
		display: grid;
		grid-template-columns: minmax(0, 1.2fr) minmax(320px, 0.9fr);
		gap: 1rem;
		align-items: stretch;
	}

	h1,
	h2,
	h3,
	p {
		margin-top: 0;
	}

	h1 {
		font-size: clamp(2.8rem, 6vw, 5.2rem);
		line-height: 0.98;
		font-weight: 500;
		max-width: 12ch;
		margin: 1.5rem 0;
	}

	h2 {
		font-size: clamp(1.85rem, 3.6vw, 3rem);
		line-height: 1.05;
		font-weight: 500;
		max-width: 15ch;
		margin: 1.5rem 0;
	}

	h3 {
		font-size: 1.3rem;
		font-weight: 500;
		margin: 1.5rem 0;
	}

	.lede,
	.info-panel p,
	.mission-card p,
	.compact-text,
	.contact-meta p {
		font-size: 0.98rem;
		line-height: 1.75;
		color: rgba(237, 243, 255, 0.86);
	}

	.hero-copy {
		padding: 1.2rem;
	}

	.action-row,
	.contact-meta {
		display: flex;
		flex-wrap: wrap;
		gap: 0.8rem;
		align-items: center;
	}

	.contact-links {
		display: flex;
		flex-wrap: wrap;
		gap: 0.8rem;
	}

	.button-primary,
	.button-secondary {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		min-height: 3rem;
		padding: 0.82rem 1.2rem;
		border-radius: 999px;
		text-decoration: none;
		text-transform: uppercase;
		letter-spacing: 0.14em;
		font-size: 0.72rem;
	}

	.button-primary {
		background: #dce7fa;
		color: #07101b;
		font-weight: 700;
	}

	.button-secondary {
		border: 1px solid rgba(191, 210, 245, 0.18);
		background: rgba(255, 255, 255, 0.03);
		color: #edf3ff;
	}

	.scanner-panel {
		display: grid;
		grid-template-rows: auto auto;
		gap: 1rem;
		padding: 1.2rem;
	}

	.scanner-graphic {
		position: relative;
		min-height: 24rem;
		border: 1px solid rgba(191, 210, 245, 0.12);
		border-radius: 1rem;
		background:
			radial-gradient(circle at center, rgba(191, 210, 245, 0.08), transparent 38%),
			linear-gradient(180deg, rgba(255, 255, 255, 0.015), rgba(255, 255, 255, 0.01));
		overflow: hidden;
	}

	.scanner-boot {
		opacity: 0;
		transform: scale(0.94);
		animation: scanner-boot 900ms cubic-bezier(0.16, 1, 0.3, 1) 120ms forwards;
	}

	.scanner-target {
		padding: 0;
		border: 0;
		cursor: pointer;
		background: transparent;
	}

	.ring,
	.axis,
	.sun-core,
	.node,
	.scan-line {
		position: absolute;
	}

	.ring {
		left: 50%;
		top: 50%;
		transform: translate(-50%, -50%);
		border: 1px solid rgba(191, 210, 245, 0.18);
		border-radius: 50%;
		z-index: 1;
	}

	.ring-1 {
		width: 18rem;
		height: 18rem;
	}

	.ring-2 {
		width: 12rem;
		height: 12rem;
	}

	.ring-3 {
		width: 6rem;
		height: 6rem;
	}

	.axis-h {
		left: 2rem;
		right: 2rem;
		top: 50%;
		height: 1px;
		background: rgba(191, 210, 245, 0.12);
		z-index: 1;
	}

	.axis-v {
		top: 2rem;
		bottom: 2rem;
		left: 50%;
		width: 1px;
		background: rgba(191, 210, 245, 0.12);
		z-index: 1;
	}

	.sun-core {
		left: 50%;
		top: 50%;
		width: 1.8rem;
		height: 1.8rem;
		border-radius: 50%;
		background: radial-gradient(circle, #fff7dc 0%, #f6d48f 45%, #b98a46 100%);
		box-shadow:
			0 0 24px rgba(246, 212, 143, 0.95),
			0 0 54px rgba(246, 212, 143, 0.52),
			0 0 90px rgba(246, 212, 143, 0.24);
		transform: translate(-50%, -50%);
		animation: sun-pulse 4.2s ease-in-out infinite;
		z-index: 3;
	}

	.sun-core:hover,
	.sun-core:focus-visible,
	.node:hover,
	.node:focus-visible {
		outline: none;
		filter: brightness(1.15);
	}

	.scanner-target:hover,
	.scanner-target:focus-visible {
		outline: none;
		filter: brightness(1.15);
	}

	.scanner-target.is-activated {
		animation: marker-activate 900ms ease-in-out;
	}

	.sun-core.is-activated {
		animation:
			sun-pulse 4.2s ease-in-out infinite,
			sun-activate 900ms ease-in-out;
	}

	.sun-core::before,
	.sun-core::after {
		content: '';
		position: absolute;
		left: 50%;
		top: 50%;
		border-radius: 50%;
		transform: translate(-50%, -50%);
	}

	.sun-core::before {
		width: 3.4rem;
		height: 3.4rem;
		border: 1px solid rgba(246, 212, 143, 0.28);
	}

	.sun-core::after {
		width: 6rem;
		height: 6rem;
		background: radial-gradient(circle, rgba(246, 212, 143, 0.26), transparent 72%);
	}

	.node {
		--orbit-size: 18rem;
		--orbit-duration: 18s;
		--orbit-angle: 0deg;
		width: 0.55rem;
		height: 0.55rem;
		border-radius: 50%;
		background: #dce7fa;
		box-shadow: 0 0 12px rgba(220, 231, 250, 0.5);
		left: 50%;
		top: 50%;
		transform:
			translate(-50%, -50%)
			rotate(var(--orbit-angle))
			translateX(calc(var(--orbit-size) / 2))
			rotate(calc(var(--orbit-angle) * -1));
		animation: orbit-spin var(--orbit-duration) linear infinite;
		z-index: 2;
		transition: box-shadow 180ms ease;
	}

	.node.is-activated {
		animation:
			orbit-spin var(--orbit-duration) linear infinite,
			planet-activate 900ms ease-in-out;
		box-shadow:
			0 0 0 0.18rem rgba(220, 231, 250, 0.12),
			0 0 18px rgba(220, 231, 250, 0.8);
	}

	.node-1 {
		--orbit-size: 18rem;
		--orbit-duration: 16s;
		--orbit-angle: 0deg;
	}

	.node-2 {
		--orbit-size: 12rem;
		--orbit-duration: 11s;
		--orbit-angle: 120deg;
	}

	.node-3 {
		--orbit-size: 18rem;
		--orbit-duration: 23s;
		--orbit-angle: 240deg;
	}

	.scan-line {
		left: 1.2rem;
		right: 1.2rem;
		top: 34%;
		height: 1px;
		background: linear-gradient(90deg, transparent, rgba(220, 231, 250, 0.7), transparent);
		box-shadow: 0 0 14px rgba(220, 231, 250, 0.28);
		z-index: 4;
		animation: scan-drift 6.8s ease-in-out infinite;
	}

	.scanner-readout {
		display: grid;
		grid-template-columns: 1fr;
		gap: 1px;
		background: rgba(191, 210, 245, 0.09);
	}

	.scanner-readout > div {
		padding: 0.9rem 1rem;
		background: rgba(12, 18, 30, 0.98);
	}

	.overview-grid {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 1rem;
		margin-bottom: 3.5rem;
	}

	.info-panel {
		padding: 1.2rem;
	}

	.section-head {
		margin-bottom: 1.2rem;
	}

	.mission-grid {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 1rem;
		margin-bottom: 3.5rem;
	}

	.mission-card {
		padding: 1.2rem;
		display: flex;
		flex-direction: column;
		gap: 0.95rem;
		min-height: 18rem;
	}

	.mission-top,
	.stat-row {
		display: flex;
		flex-wrap: wrap;
		justify-content: space-between;
		gap: 0.65rem;
	}

	.mission-code {
		font-size: 0.72rem;
		color: #dce7fa;
	}

	.stat-row {
		padding-top: 0.2rem;
		border-top: 1px solid rgba(191, 210, 245, 0.1);
	}

	.text-link {
		margin-top: auto;
		color: #dce7fa;
		text-decoration: none;
		text-transform: uppercase;
		letter-spacing: 0.14em;
		font-size: 0.72rem;
	}

	.systems-layout {
		display: grid;
		grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
		gap: 1rem;
		margin-bottom: 2rem;
	}

	.systems-panel {
		padding: 1rem;
		display: grid;
		gap: 1px;
		background: rgba(191, 210, 245, 0.08);
	}

	.system-row {
		padding: 0.95rem 1rem;
		background: rgba(12, 18, 30, 0.98);
	}

	.contact-panel {
		display: flex;
		justify-content: space-between;
		align-items: end;
		gap: 1rem;
		padding: 1.25rem;
	}

	@keyframes lift-in {
		from {
			opacity: 0;
			transform: translateY(18px);
		}

		to {
			opacity: 1;
			transform: translateY(0);
		}
	}

	@keyframes scanner-boot {
		0% {
			opacity: 0;
			transform: scale(0.94);
			filter: brightness(0.72) blur(8px);
		}

		55% {
			opacity: 1;
			transform: scale(1.02);
			filter: brightness(1.08) blur(0);
		}

		100% {
			opacity: 1;
			transform: scale(1);
			filter: brightness(1) blur(0);
		}
	}

	@keyframes interface-reveal {
		from {
			opacity: 0;
			transform: translateY(18px);
			filter: blur(8px);
		}

		to {
			opacity: 1;
			transform: translateY(0);
			filter: blur(0);
		}
	}

	@keyframes orbit-spin {
		from {
			transform:
				translate(-50%, -50%)
				rotate(var(--orbit-angle))
				translateX(calc(var(--orbit-size) / 2))
				rotate(calc(var(--orbit-angle) * -1));
		}

		to {
			transform:
				translate(-50%, -50%)
				rotate(calc(var(--orbit-angle) + 360deg))
				translateX(calc(var(--orbit-size) / 2))
				rotate(calc((var(--orbit-angle) + 360deg) * -1));
		}
	}

	@keyframes sun-pulse {
		0%,
		100% {
			transform: translate(-50%, -50%) scale(1);
			box-shadow:
				0 0 24px rgba(246, 212, 143, 0.95),
				0 0 54px rgba(246, 212, 143, 0.52),
				0 0 90px rgba(246, 212, 143, 0.24);
		}

		50% {
			transform: translate(-50%, -50%) scale(1.12);
			box-shadow:
				0 0 28px rgba(246, 212, 143, 1),
				0 0 60px rgba(246, 212, 143, 0.6),
				0 0 100px rgba(246, 212, 143, 0.28);
		}
	}

	@keyframes sun-activate {
		0%,
		100% {
			transform: translate(-50%, -50%) scale(1);
		}

		20% {
			transform: translate(calc(-50% - 0.04rem), calc(-50% + 0.02rem)) scale(1.05);
		}

		40% {
			transform: translate(calc(-50% + 0.04rem), calc(-50% - 0.03rem)) scale(1.1);
		}

		60% {
			transform: translate(calc(-50% - 0.03rem), calc(-50% - 0.02rem)) scale(1.07);
		}

		80% {
			transform: translate(calc(-50% + 0.02rem), calc(-50% + 0.03rem)) scale(1.03);
		}
	}

	@keyframes planet-activate {
		0%,
		100% {
			filter: brightness(1);
		}

		25% {
			filter: brightness(1.16);
		}

		50% {
			filter: brightness(1.32);
		}

		75% {
			filter: brightness(1.14);
		}
	}

	@keyframes marker-activate {
		0%,
		100% {
			filter: brightness(1);
		}

		30% {
			filter: brightness(1.28);
		}

		60% {
			filter: brightness(1.12);
		}
	}

	@keyframes sun-marker-glow {
		0%,
		100% {
			box-shadow:
				0 0 18px rgba(246, 212, 143, 0.95),
				0 0 34px rgba(246, 212, 143, 0.34);
		}

		50% {
			box-shadow:
				0 0 24px rgba(246, 212, 143, 1),
				0 0 48px rgba(246, 212, 143, 0.48);
		}
	}

	@keyframes scan-drift {
		0%,
		100% {
			top: 20%;
			opacity: 0.24;
		}

		50% {
			top: 78%;
			opacity: 0.65;
		}
	}

	@media (max-width: 980px) {
		.frame-header,
		.frame-body,
		.overview-grid,
		.mission-grid,
		.systems-layout,
		.contact-panel {
			grid-template-columns: 1fr;
		}

		.contact-panel {
			align-items: start;
		}
	}

	@media (max-width: 720px) {
		.shell {
			width: min(100% - 1rem, 1200px);
		}

		.topbar {
			flex-direction: column;
			align-items: start;
		}

		h1 {
			max-width: 10ch;
		}

		.scanner-graphic {
			min-height: 19rem;
		}

		.ring-1 {
			width: 13rem;
			height: 13rem;
		}

		.ring-2 {
			width: 9rem;
			height: 9rem;
		}

		.ring-3 {
			width: 4.5rem;
			height: 4.5rem;
		}
	}
</style>

<script>
	const backdrop = document.querySelector('#three-backdrop');
	const scannerSceneHost = document.querySelector('#scanner-scene');
	const scannerTargets = Array.from(document.querySelectorAll('.scanner-target'));
	const scannerTargetMap = new Map(
		scannerTargets.map((target) => [target.dataset.target ?? '', target]),
	);
	const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
	const cleanups = [];

	const restartActivation = (target) => {
		const activeClass = 'is-activated';
		target.classList.remove(activeClass);
		void target.offsetWidth;
		target.classList.add(activeClass);
	};

	scannerTargets.forEach((target) => {
		target.addEventListener('click', () => restartActivation(target));
	});

	const THREE = await import('three');

	if (scannerSceneHost) {
		const scene = new THREE.Scene();
		const camera = new THREE.PerspectiveCamera(28, 1, 0.1, 100);
		camera.position.set(0, 0, 26);

		const renderer = new THREE.WebGLRenderer({ antialias: true, alpha: true });
		renderer.setPixelRatio(Math.min(window.devicePixelRatio, 1.6));
		renderer.setClearColor(0x000000, 0);
		scannerSceneHost.append(renderer.domElement);

		const root = new THREE.Group();
		scene.add(root);

		const orbiter = new THREE.Group();
		root.add(orbiter);

		const temporaryVector = new THREE.Vector3();
		const disposables = [];
		const register = (resource) => {
			disposables.push(resource);
			return resource;
		};
		const createRadialGlowTexture = (innerColor, outerColor) => {
			const size = 256;
			const canvas = document.createElement('canvas');
			canvas.width = size;
			canvas.height = size;
			const context = canvas.getContext('2d');
			if (!context) return null;
			const gradient = context.createRadialGradient(
				size / 2,
				size / 2,
				0,
				size / 2,
				size / 2,
				size / 2,
			);
			gradient.addColorStop(0, innerColor);
			gradient.addColorStop(0.35, 'rgba(255, 230, 180, 0.22)');
			gradient.addColorStop(1, outerColor);
			context.fillStyle = gradient;
			context.fillRect(0, 0, size, size);
			return register(new THREE.CanvasTexture(canvas));
		};

		const sun = new THREE.Mesh(
			register(new THREE.SphereGeometry(0.56, 24, 24)),
			register(
				new THREE.MeshBasicMaterial({
					color: 0xf8d48d,
					transparent: true,
					opacity: 0.98,
				}),
			),
		);
		orbiter.add(sun);

		const sunHalo = new THREE.Mesh(
			register(new THREE.RingGeometry(0.92, 1.38, 48)),
			register(
				new THREE.MeshBasicMaterial({
					color: 0xf6d48f,
					transparent: true,
					opacity: 0.24,
					side: THREE.DoubleSide,
				}),
			),
		);
		sunHalo.rotation.x = Math.PI / 2;
		orbiter.add(sunHalo);

		const sunGlowTexture = createRadialGlowTexture(
			'rgba(255, 232, 188, 0.55)',
			'rgba(255, 232, 188, 0)',
		);
		const glowSprite = new THREE.Sprite(
			register(
				new THREE.SpriteMaterial({
					map: sunGlowTexture,
					transparent: true,
					opacity: 0.36,
					depthWrite: false,
				}),
			),
		);
		glowSprite.scale.set(5.6, 5.6, 1);
		glowSprite.position.z = -0.2;
		orbiter.add(glowSprite);

		const orbitMaterial = register(
			new THREE.LineBasicMaterial({
				color: 0x8eaee0,
				transparent: true,
				opacity: 0.24,
			}),
		);

		const makeOrbit = (radiusX, radiusY, rotationZ = 0) => {
			const points = [];
			for (let step = 0; step <= 180; step += 1) {
				const angle = (step / 180) * Math.PI * 2;
				points.push(new THREE.Vector3(Math.cos(angle) * radiusX, Math.sin(angle) * radiusY, 0));
			}

			const orbit = new THREE.LineLoop(
				register(new THREE.BufferGeometry().setFromPoints(points)),
				orbitMaterial,
			);
			orbit.rotation.z = rotationZ;
			orbiter.add(orbit);
		};

		makeOrbit(6.1, 6.1, 0);
		makeOrbit(4.35, 4.35, 0);
		makeOrbit(8, 8, 0);

		const planetGeometry = register(new THREE.SphereGeometry(0.18, 18, 18));
		const createPlanet = (color) =>
			new THREE.Mesh(
				planetGeometry,
				register(
					new THREE.MeshBasicMaterial({
						color,
						transparent: true,
						opacity: 0.98,
					}),
				),
			);

		const planets = [
			{
				id: 'aurelia',
				mesh: createPlanet(0xdce9ff),
				radiusX: 6.1,
				radiusY: 6.1,
				speed: 0.44,
				offset: 0.45,
				lift: 0,
			},
			{
				id: 'vesper',
				mesh: createPlanet(0xb8cff7),
				radiusX: 4.35,
				radiusY: 4.35,
				speed: 0.76,
				offset: 2.1,
				lift: 0,
			},
			{
				id: 'khepri',
				mesh: createPlanet(0xf0f6ff),
				radiusX: 8,
				radiusY: 8,
				speed: 0.31,
				offset: 4.0,
				lift: 0,
			},
		];

		planets.forEach((planet) => orbiter.add(planet.mesh));

		const comet = new THREE.Group();
		const cometTailGeometry = register(
			new THREE.BufferGeometry().setFromPoints([
				new THREE.Vector3(-1.9, 0, 0),
				new THREE.Vector3(0, 0, 0),
			]),
		);
		const cometTail = new THREE.Line(
			cometTailGeometry,
			register(
				new THREE.LineBasicMaterial({
					color: 0xe0edff,
					transparent: true,
					opacity: 0.42,
				}),
			),
		);
		const cometCore = new THREE.Mesh(
			register(new THREE.SphereGeometry(0.14, 12, 12)),
			register(
				new THREE.MeshBasicMaterial({
					color: 0xf6fbff,
					transparent: true,
					opacity: 0.96,
				}),
			),
		);
		comet.add(cometTail);
		comet.add(cometCore);
		comet.rotation.z = 0.34;
		comet.visible = false;
		root.add(comet);

		const resize = () => {
			const width = scannerSceneHost.clientWidth || 1;
			const height = scannerSceneHost.clientHeight || 1;
			camera.aspect = width / height;
			camera.updateProjectionMatrix();
			renderer.setSize(width, height, false);
			renderer.setPixelRatio(Math.min(window.devicePixelRatio, 1.6));
			renderer.render(scene, camera);
			placeMarker('sun', sun);
			planets.forEach((planet) => placeMarker(planet.id, planet.mesh));
		};

		const placeMarker = (key, source) => {
			const target = scannerTargetMap.get(key);
			if (!target) return;
			source.getWorldPosition(temporaryVector);
			temporaryVector.project(camera);
			const width = scannerSceneHost.clientWidth;
			const height = scannerSceneHost.clientHeight;
			target.style.left = `${(temporaryVector.x * 0.5 + 0.5) * width}px`;
			target.style.top = `${(-temporaryVector.y * 0.5 + 0.5) * height}px`;
		};

		resize();

		if (prefersReducedMotion) {
			planets.forEach((planet) => {
				planet.mesh.position.set(
					Math.cos(planet.offset) * planet.radiusX,
					Math.sin(planet.offset) * planet.radiusY,
					0,
				);
			});
			renderer.render(scene, camera);
			placeMarker('sun', sun);
			planets.forEach((planet) => placeMarker(planet.id, planet.mesh));
		} else {
			const clock = new THREE.Clock();
			let rafId = 0;

			const animate = () => {
				const elapsed = clock.getElapsedTime();
				sun.scale.setScalar(1 + Math.sin(elapsed * 1.7) * 0.055);
				sunHalo.rotation.z = elapsed * 0.22;
				sunHalo.scale.setScalar(1 + Math.sin(elapsed * 1.3) * 0.04);
				glowSprite.rotation.z = -elapsed * 0.06;
				orbiter.rotation.z = 0;
				orbiter.rotation.y = 0;

				planets.forEach((planet) => {
					const angle = elapsed * planet.speed + planet.offset;
					planet.mesh.position.set(
						Math.cos(angle) * planet.radiusX,
						Math.sin(angle) * planet.radiusY,
						0,
					);
				});

				const cometCycle = elapsed % 16;
				if (cometCycle > 11.2 && cometCycle < 13.5) {
					const t = (cometCycle - 11.2) / 2.3;
					comet.visible = true;
					comet.position.set(
						THREE.MathUtils.lerp(-8.8, 8.8, t),
						THREE.MathUtils.lerp(4.4, -4.4, t),
						0,
					);
					comet.scale.setScalar(0.92 + t * 0.16);
					comet.children.forEach((child) => {
						child.material.opacity = t < 0.2 ? t * 2.5 : t > 0.82 ? (1 - t) * 5 : 1;
					});
				} else {
					comet.visible = false;
				}

				renderer.render(scene, camera);
				placeMarker('sun', sun);
				planets.forEach((planet) => placeMarker(planet.id, planet.mesh));
				rafId = window.requestAnimationFrame(animate);
			};

			animate();
			cleanups.push(() => window.cancelAnimationFrame(rafId));
		}

		window.addEventListener('resize', resize);
		cleanups.push(() => {
			window.removeEventListener('resize', resize);
			disposables.forEach((resource) => resource.dispose?.());
			renderer.dispose();
		});
	}

	if (backdrop && !prefersReducedMotion) {
		const scene = new THREE.Scene();
		const camera = new THREE.PerspectiveCamera(48, window.innerWidth / window.innerHeight, 0.1, 100);
		camera.position.z = 18;

		const renderer = new THREE.WebGLRenderer({ antialias: true, alpha: true });
		renderer.setPixelRatio(Math.min(window.devicePixelRatio, 1.8));
		renderer.setSize(window.innerWidth, window.innerHeight);
		renderer.setClearColor(0x000000, 0);
		backdrop.append(renderer.domElement);

		const root = new THREE.Group();
		scene.add(root);
		const createBackdropGlowTexture = (innerColor, outerColor) => {
			const size = 256;
			const canvas = document.createElement('canvas');
			canvas.width = size;
			canvas.height = size;
			const context = canvas.getContext('2d');
			if (!context) return null;
			const gradient = context.createRadialGradient(
				size / 2,
				size / 2,
				0,
				size / 2,
				size / 2,
				size / 2,
			);
			gradient.addColorStop(0, innerColor);
			gradient.addColorStop(0.4, 'rgba(180, 208, 255, 0.12)');
			gradient.addColorStop(1, outerColor);
			context.fillStyle = gradient;
			context.fillRect(0, 0, size, size);
			return new THREE.CanvasTexture(canvas);
		};

		const starGeometry = new THREE.BufferGeometry();
		const starCount = 700;
		const starPositions = new Float32Array(starCount * 3);

		for (let i = 0; i < starCount; i += 1) {
			const i3 = i * 3;
			starPositions[i3] = (Math.random() - 0.5) * 34;
			starPositions[i3 + 1] = (Math.random() - 0.5) * 22;
			starPositions[i3 + 2] = (Math.random() - 0.5) * 16;
		}

		starGeometry.setAttribute('position', new THREE.BufferAttribute(starPositions, 3));

		const stars = new THREE.Points(
			starGeometry,
			new THREE.PointsMaterial({
				color: 0xcfe2ff,
				size: 0.05,
				transparent: true,
				opacity: 0.75,
				depthWrite: false,
			}),
		);
		root.add(stars);

		const glowATexture = createBackdropGlowTexture(
			'rgba(173, 203, 255, 0.34)',
			'rgba(173, 203, 255, 0)',
		);
		const glowA = new THREE.Sprite(
			new THREE.SpriteMaterial({
				map: glowATexture,
				transparent: true,
				opacity: 0.22,
				depthWrite: false,
			}),
		);
		glowA.scale.set(14, 14, 1);
		glowA.position.set(-3.5, 1.4, -6);
		root.add(glowA);

		const glowBTexture = createBackdropGlowTexture(
			'rgba(255, 220, 170, 0.22)',
			'rgba(255, 220, 170, 0)',
		);
		const glowB = new THREE.Sprite(
			new THREE.SpriteMaterial({
				map: glowBTexture,
				transparent: true,
				opacity: 0.16,
				depthWrite: false,
			}),
		);
		glowB.scale.set(10, 10, 1);
		glowB.position.set(5.2, -3.3, -7);
		root.add(glowB);

		const pointer = { x: 0, y: 0 };
		const clock = new THREE.Clock();
		let rafId = 0;

		const onPointerMove = (event) => {
			pointer.x = (event.clientX / window.innerWidth - 0.5) * 2;
			pointer.y = (event.clientY / window.innerHeight - 0.5) * 2;
		};

		const onResize = () => {
			camera.aspect = window.innerWidth / window.innerHeight;
			camera.updateProjectionMatrix();
			renderer.setSize(window.innerWidth, window.innerHeight);
			renderer.setPixelRatio(Math.min(window.devicePixelRatio, 1.8));
		};

		const animate = () => {
			const elapsed = clock.getElapsedTime();
			stars.rotation.z = elapsed * 0.01;
			stars.rotation.x = Math.sin(elapsed * 0.12) * 0.02;
			root.rotation.y += (pointer.x * 0.12 - root.rotation.y) * 0.03;
			root.rotation.x += (-pointer.y * 0.08 - root.rotation.x) * 0.03;
			glowA.rotation.z = elapsed * 0.03;
			glowB.rotation.z = -elapsed * 0.02;
			renderer.render(scene, camera);
			rafId = window.requestAnimationFrame(animate);
		};

		window.addEventListener('pointermove', onPointerMove, { passive: true });
		window.addEventListener('resize', onResize);
		animate();

		cleanups.push(() => {
			window.cancelAnimationFrame(rafId);
			window.removeEventListener('pointermove', onPointerMove);
			window.removeEventListener('resize', onResize);
			starGeometry.dispose();
			glowATexture?.dispose();
			glowBTexture?.dispose();
			glowA.material.dispose();
			glowB.material.dispose();
			renderer.dispose();
		});
	}

	window.addEventListener(
		'pagehide',
		() => {
			cleanups.forEach((cleanup) => cleanup());
		},
		{ once: true },
	);
</script>
